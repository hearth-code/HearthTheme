        "terminal.ansiBrightBlue": "#658d85",
        "terminal.ansiBrightMagenta": "#b9758b",
        "terminal.ansiBrightCyan": "#70946f",
        "terminal.ansiBrightWhite": "#2d241e",
        "terminalCursor.foreground": "#62836c",
