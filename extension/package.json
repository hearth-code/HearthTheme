        "eye strain",
        "readable",
        "hearth"
    ],
    "galleryBanner": {
        "color": "#1e1a12",
        "theme": "dark"
    },
    "icon": "icon.png",
    "homepage": "https://theme.hearthcode.dev",
    "repository": {
        "type": "git",
        "url": "https://github.com/TypeFusion/HearthTheme"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.7.1"
    },
    "license": "MIT",
    "contributes": {
        "themes": [
            {
                "label": "Hearth Dark",
                "uiTheme": "vs-dark",
                "path": "./themes/hearth-dark.json"
