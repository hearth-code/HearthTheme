    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#837d76",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#a65c4b",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#6f6861",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "meta.function-call entity.name.function",
                "meta.function-call.js entity.name.function.js",
                "meta.function-call.ts entity.name.function.ts",
                "meta.function-call.py entity.name.function.py",
                "meta.function-call.python entity.name.function.python",
                "meta.function-call.go entity.name.function.go",
                "meta.function-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#58717b"
            }
        },
        {
            "scope": [
                "meta.method-call entity.name.function",
                "meta.method-call.js entity.name.function.js",
                "meta.method-call.ts entity.name.function.ts",
                "meta.method-call.py entity.name.function.py",
                "meta.method-call.python entity.name.function.python",
                "meta.method-call.go entity.name.function.go",
                "meta.method-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#8d4b2a"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#58717b"
            }
        },
        {
            "scope": [
                "entity.name.function.member",
                "entity.name.function.member.python",
                "entity.name.function.member.go",
                "entity.name.function.member.rust"
            ],
            "settings": {
                "foreground": "#8d4b2a"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "variable.other.member",
                "meta.property-name",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#5d6646"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#708561"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#91667c"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "storage.type.java",
                "storage.type.primitive.java",
                "entity.name.struct.rust",
                "entity.name.type.class",
                "support.type",
                "support.type.builtin",
                "support.class"
            ],
            "settings": {
                "foreground": "#837d48",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#534f48"
            }
        },
        {
            "scope": [
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#9d6c51"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#966847"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#844c3e"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#9b6735",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#817054"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#91667c"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#966835",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#b25f4f",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#9a673f",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#467e49"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#467e49"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#ab5b4f",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#a85d4f",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#534f48",
        "variable.readonly": "#9a673f",
        "property": "#5d6646",
        "property.readonly": "#9b6737",
        "function": "#58717b",
        "method": "#8d4b2a",
        "function.defaultLibrary": "#58717b",
        "method.defaultLibrary": "#8d4b2a",
        "class": {
            "foreground": "#837d48",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#837d48",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#837d48",
            "fontStyle": "italic"
        },
        "type.defaultLibrary": {
            "foreground": "#837d48",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#837d48",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#837d48",
            "fontStyle": "italic"
        },
        "enumMember": "#91667c",
        "namespace": "#846f52",
        "keyword": {
            "foreground": "#a65c4b",
            "fontStyle": "bold"
        },
        "parameter": "#68584b",
        "variable.defaultLibrary": "#9b6735",
        "decorator": {
            "foreground": "#9b6735",
            "fontStyle": "italic"
        }
    }
}
