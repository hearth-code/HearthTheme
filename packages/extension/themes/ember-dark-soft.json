    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#80796b",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#d8815d",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#959391",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "meta.function-call entity.name.function",
                "meta.function-call.js entity.name.function.js",
                "meta.function-call.ts entity.name.function.ts",
                "meta.function-call.py entity.name.function.py",
                "meta.function-call.python entity.name.function.python",
                "meta.function-call.go entity.name.function.go",
                "meta.function-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#a3d076"
            }
        },
        {
            "scope": [
                "meta.method-call entity.name.function",
                "meta.method-call.js entity.name.function.js",
                "meta.method-call.ts entity.name.function.ts",
                "meta.method-call.py entity.name.function.py",
                "meta.method-call.python entity.name.function.python",
                "meta.method-call.go entity.name.function.go",
                "meta.method-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#8eb369"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#a3d076"
            }
        },
        {
            "scope": [
                "entity.name.function.member",
                "entity.name.function.member.python",
                "entity.name.function.member.go",
                "entity.name.function.member.rust"
            ],
            "settings": {
                "foreground": "#8eb369"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "variable.other.member",
                "meta.property-name",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#8eafa8"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#dfbe7b"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#e0a97c"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "storage.type.java",
                "storage.type.primitive.java",
                "entity.name.struct.rust",
                "entity.name.type.class",
                "support.type",
                "support.type.builtin",
                "support.class"
            ],
            "settings": {
                "foreground": "#6a9eb9",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#cecbc5"
            }
        },
        {
            "scope": [
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#b7774f"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#62b8dc"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#aacd85"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#caa46c",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#b8ad9b"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#e0a97c"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#e1ba73",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#c26f59",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#c89254",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#8fbd79"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#8fbd79"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#ca8364",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#ca8364",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#cecbc5",
        "variable.readonly": "#c89254",
        "property": "#8eafa8",
        "property.readonly": "#c89254",
        "function": "#a3d076",
        "method": "#8eb369",
        "function.defaultLibrary": "#a3d076",
        "method.defaultLibrary": "#8eb369",
        "class": {
            "foreground": "#6a9eb9",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#6a9eb9",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#6a9eb9",
            "fontStyle": "italic"
        },
        "type.defaultLibrary": {
            "foreground": "#6a9eb9",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#6a9eb9",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#6a9eb9",
            "fontStyle": "italic"
        },
        "enumMember": "#e0a97c",
        "namespace": "#d6cab4",
        "keyword": {
            "foreground": "#d8815d",
            "fontStyle": "bold"
        },
        "parameter": "#c6b49f",
        "variable.defaultLibrary": "#caa46c",
        "decorator": {
            "foreground": "#caa46c",
            "fontStyle": "italic"
        }
    }
}
