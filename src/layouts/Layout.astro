---
import "../styles/global.css";
import { t, languages, type Lang } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	lang?: Lang;
}

const { lang = "en", title, description } = Astro.props;
const url = Astro.url;
const baseUrl = import.meta.env.BASE_URL;
const basePath = baseUrl === "/" ? "" : baseUrl.replace(/\/$/, "");
const withBase = (path: string) => {
	const normalized = path.startsWith("/") ? path : `/${path}`;
	if (!basePath) return normalized;
	return normalized === "/" ? `${basePath}/` : `${basePath}${normalized}`;
};

const pageTitle = title ? `${title} — HearthCode` : "HearthCode — VSCode Color Theme";

const pageDescription = description ?? t(lang, "hero.subtitle");

const home = withBase(lang === "en" ? "/" : `/${lang}`);
const docs = withBase(lang === "en" ? "/docs" : `/${lang}/docs`);
const marketplaceUrl = "https://marketplace.visualstudio.com/items?itemName=hearth-code.hearth-theme";
const isDocsPage = /\/docs\/?$/.test(url.pathname);
const isHomePage = !isDocsPage;
const installFontClass = "font-ui tracking-[0.03em] sm:tracking-[0.04em]";
const footerMetaClass = "font-ui hearth-meta text-[#504838]";
const siteBase = Astro.site ?? new URL(url.origin);
const langHref = (target: Lang) =>
	withBase(
		isDocsPage
		? target === "en"
			? "/docs"
			: `/${target}/docs`
		: target === "en"
			? "/"
			: `/${target}`,
	);
const absoluteLangHref = (target: Lang) => new URL(langHref(target), siteBase).href;
const canonicalUrl = new URL(url.pathname + url.search, siteBase).href;
const defaultUrl = new URL(withBase(isDocsPage ? "/docs" : "/"), siteBase).href;
const ogImage = new URL(withBase("/og-hearth.png"), siteBase).href;
---

<!doctype html>
<html lang={lang} data-base-path={basePath}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={pageDescription} />
		<meta name="author" content="HearthCode" />
		<meta name="theme-color" content="#23201c" />

		<!-- Open Graph -->
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="HearthCode" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content="HearthCode Theme preview" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<!-- hreflang for i18n SEO -->
		{
			Object.keys(languages).map((l) => (
				<link
					rel="alternate"
					hreflang={l}
					href={absoluteLangHref(l as Lang)}
				/>
			))
		}
		<link rel="alternate" hreflang="x-default" href={defaultUrl} />
		<link rel="canonical" href={canonicalUrl} />

		<link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
		<link rel="icon" type="image/png" sizes="512x512" href={withBase("/icon-512.png")} />
		<link rel="apple-touch-icon" href={withBase("/icon-512.png")} />
		<title>{pageTitle}</title>
	</head>
	<body class="app-shell">
		<!-- Nav -->
		<nav class="hearth-topbar">
			<div class="hearth-topbar-inner">
				<a
					href={home}
					class="hearth-brand"
				>
					<img
						src={withBase("/favicon.svg")}
						alt="HearthCode"
						class="h-6 w-6 rounded-md bg-[#171411] p-0.5 shadow-[0_6px_16px_rgba(0,0,0,0.22)]"
					/>
					<span class="hearth-brand-label">
						<span class="hearth-brand-hearth">Hearth</span>
						<span class="hearth-brand-code">Code</span>
					</span>
				</a>

				<div class="hearth-topbar-actions">
					<div class="hearth-nav-cluster">
						<a
							href={home}
							class={`hearth-nav-pill ${isHomePage ? "is-active" : ""}`}
							aria-current={isHomePage ? "page" : undefined}
						>
							{t(lang, "nav.home")}
						</a>
						<a
							href={docs}
							class={`hearth-nav-pill ${isDocsPage ? "is-active" : ""}`}
							aria-current={isDocsPage ? "page" : undefined}
						>
							{t(lang, "nav.docs")}
						</a>
					</div>

					<a
						href={marketplaceUrl}
						target="_blank"
						rel="noopener noreferrer"
						class={`hearth-install ${installFontClass}`}
					>
						<span>{t(lang, "nav.install")}</span>
						<span aria-hidden="true" class="text-[0.95em]">↗</span>
					</a>

					<div class="hearth-lang-cluster" aria-label="language switch">
						<a
							href={langHref("en")}
							data-lang="en"
							class={`hearth-lang-pill ${lang === "en" ? "is-active" : ""}`}
						>
							EN
						</a>
						<a
							href={langHref("zh")}
							data-lang="zh"
							class={`hearth-lang-pill ${lang === "zh" ? "is-active" : ""}`}
						>
							中
						</a>
						<a
							href={langHref("ja")}
							data-lang="ja"
							class={`hearth-lang-pill ${lang === "ja" ? "is-active" : ""}`}
						>
							日
						</a>
					</div>
				</div>
			</div>
		</nav>

		<!-- Page content -->
		<main class="pt-[82px] sm:pt-[92px]">
			<slot />
		</main>

		<!-- Footer -->
		<footer
			class="mt-6 px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-0 justify-between bg-[linear-gradient(180deg,rgba(255,255,255,0.015),rgba(0,0,0,0.04))]"
		>
			<span class="font-ui font-semibold tracking-[-0.01em] text-[1.05rem]">
				<span class="text-[#d9cfbc]">Hearth</span>
				<span class="text-[#d39b58] ml-1">Code</span>
			</span>
			<span class={footerMetaClass}>
				HearthCode.dev &nbsp;·&nbsp; {t(lang, "footer.tagline")}
			</span>
		</footer>
		<script is:inline>
			(() => {
				const BASE_PATH = document.documentElement.getAttribute("data-base-path") || "";
				const normalizeLang = (value) => {
					if (!value) return null;
					const code = String(value).toLowerCase();
					if (code.startsWith("zh")) return "zh";
					if (code.startsWith("ja")) return "ja";
					if (code.startsWith("en")) return "en";
					return null;
				};
				const stripBase = (pathname) => {
					const normalized = pathname.replace(/\/+$/, "") || "/";
					if (!BASE_PATH) return normalized;
					if (normalized === BASE_PATH) return "/";
					if (normalized.startsWith(`${BASE_PATH}/`)) {
						return normalized.slice(BASE_PATH.length) || "/";
					}
					return normalized;
				};
				const addBase = (pathname) => {
					if (!BASE_PATH) return pathname;
					if (pathname === "/") return `${BASE_PATH}/`;
					return `${BASE_PATH}${pathname}`;
				};

				const LANG_PREF_KEY = "hearth-lang";
				const currentLang = normalizeLang(document.documentElement.lang) ?? "en";
				const currentPath = stripBase(window.location.pathname);
				const isEnEntryPoint = currentLang === "en" && (currentPath === "/" || currentPath === "/docs");

				const mapTargetPath = (basePath, preferredLang) => {
					if (preferredLang === "en") return basePath;
					if (basePath === "/docs") return `/${preferredLang}/docs`;
					return `/${preferredLang}`;
				};

				if (isEnEntryPoint) {
					let preferredLang = null;
					try {
						preferredLang = normalizeLang(localStorage.getItem(LANG_PREF_KEY));
					} catch {}

					if (!preferredLang) {
						const browserLangs =
							Array.isArray(navigator.languages) && navigator.languages.length > 0
								? navigator.languages
								: [navigator.language];
						for (const browserLang of browserLangs) {
							const hit = normalizeLang(browserLang);
							if (hit === "zh" || hit === "ja") {
								preferredLang = hit;
								break;
							}
						}
					}

					if (preferredLang && preferredLang !== "en") {
						const targetPath = mapTargetPath(currentPath, preferredLang);
						if (targetPath !== currentPath) {
							const targetWithBase = addBase(targetPath);
							window.location.replace(`${targetWithBase}${window.location.search}${window.location.hash}`);
							return;
						}
					}
				}

				document.querySelectorAll(".hearth-lang-pill[data-lang]").forEach((pill) => {
					pill.addEventListener(
						"click",
						() => {
							const selected = normalizeLang(pill.getAttribute("data-lang"));
							if (!selected) return;
							try {
								localStorage.setItem(LANG_PREF_KEY, selected);
							} catch {}
						},
						{ passive: true },
					);
				});

				if (window.__hearthRevealInit) return;
				window.__hearthRevealInit = true;
				const topbar = document.querySelector(".hearth-topbar");

				const syncTopbar = () => {
					if (!topbar) return;
					topbar.classList.toggle("is-condensed", window.scrollY > 20);
				};

				syncTopbar();

				if (topbar) {
					let ticking = false;
					window.addEventListener(
						"scroll",
						() => {
							if (ticking) return;
							ticking = true;
							window.requestAnimationFrame(() => {
								syncTopbar();
								ticking = false;
							});
						},
						{ passive: true },
					);
				}

				const targets = document.querySelectorAll("[data-reveal]");
				if (!targets.length) return;

				const reveal = (el) => el.classList.add("is-visible");
				if (!("IntersectionObserver" in window)) {
					targets.forEach((el) => reveal(el));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							reveal(entry.target);
							observer.unobserve(entry.target);
						});
					},
					{ threshold: 0.14, rootMargin: "0px 0px -8% 0px" },
				);
				targets.forEach((el) => observer.observe(el));
			})();
		</script>
	</body>
</html>
