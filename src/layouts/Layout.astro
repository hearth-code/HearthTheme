---
import "../styles/global.css";
import { t, languages, type Lang } from "../i18n/utils";
import { tokens } from "../data/tokens";
import { productData } from "../data/product";

interface Props {
	title?: string;
	description?: string;
	lang?: Lang;
}

const { lang = "en", title, description } = Astro.props;
const url = Astro.url;

const brand = productData.product.wordmark;
const pageTitle = title ? `${title} — ${productData.site.titleSuffix}` : productData.site.defaultTitle;

const pageDescription = description ?? t(lang, "hero.subtitle");
const themeColor = tokens.dark.bg;

const home = lang === "en" ? "/" : `/${lang}`;
const docs = lang === "en" ? "/docs" : `/${lang}/docs`;
const marketplaceUrl = productData.links.marketplaceUrl;
const obsidianReleaseUrl = productData.links.releasesUrl;
const changelogUrl = productData.links.changelogUrl;
const issuesUrl = productData.links.issuesUrl;
const licenseUrl = productData.links.licenseUrl;
const isDocsPage = /\/docs\/?$/.test(url.pathname);
const isHomePage = !isDocsPage;
const footerMetaClass = "font-ui hearth-meta hearth-footer-meta";
const siteBase = Astro.site ?? new URL(url.origin);
const langHref = (target: Lang) =>
	isDocsPage
		? target === "en"
			? "/docs"
			: `/${target}/docs`
		: target === "en"
			? "/"
			: `/${target}`;
const absoluteLangHref = (target: Lang) => new URL(langHref(target), siteBase).href;
const canonicalUrl = new URL(url.pathname + url.search, siteBase).href;
const defaultUrl = new URL(isDocsPage ? "/docs" : "/", siteBase).href;
const ogImage = new URL(productData.site.ogImagePath, siteBase).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={pageDescription} />
		<meta name="author" content={productData.site.authorName} />
		<meta name="theme-color" content={themeColor} />
		<meta name={`${productData.site.metaPrefix}:marketplace`} content={marketplaceUrl} />
		<meta name={`${productData.site.metaPrefix}:obsidian`} content={obsidianReleaseUrl} />

		<!-- Open Graph -->
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={productData.site.titleSuffix} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={productData.site.ogImageAlt} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={ogImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Noto+Sans:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<!-- hreflang for i18n SEO -->
		{
			Object.keys(languages).map((l) => (
				<link
					rel="alternate"
					hreflang={l}
					href={absoluteLangHref(l as Lang)}
				/>
			))
		}
		<link rel="alternate" hreflang="x-default" href={defaultUrl} />
		<link rel="canonical" href={canonicalUrl} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png" />
		<link rel="apple-touch-icon" href="/icon-512.png" />
		<title>{pageTitle}</title>
	</head>
	<body class="app-shell">
		<!-- Nav -->
		<nav class="hearth-topbar">
			<div class="hearth-topbar-inner">
				<a
					href={home}
					class="hearth-brand"
				>
					<img
						src="/favicon.svg"
						alt={productData.product.name}
						class="h-6 w-6 rounded-full hearth-logo-mark"
					/>
					<span class="hearth-brand-label">
						<span class="hearth-brand-hearth">{brand.primary}</span>
						{brand.secondary ? <span class="hearth-brand-code">{brand.secondary}</span> : null}
					</span>
				</a>

				<div class="hearth-topbar-center">
					<div class="hearth-nav-cluster">
						<a
							href={home}
							class={`hearth-nav-pill ${isHomePage ? "is-active" : ""}`}
							aria-current={isHomePage ? "page" : undefined}
						>
							{t(lang, "nav.home")}
						</a>
						<a
							href={docs}
							class={`hearth-nav-pill ${isDocsPage ? "is-active" : ""}`}
							aria-current={isDocsPage ? "page" : undefined}
						>
							{t(lang, "nav.docs")}
						</a>
					</div>
				</div>

				<div class="hearth-lang-cluster" aria-label="language switch">
					<a
						href={langHref("en")}
						data-lang="en"
						class={`hearth-lang-pill ${lang === "en" ? "is-active" : ""}`}
					>
						EN
					</a>
					<a
						href={langHref("zh")}
						data-lang="zh"
						class={`hearth-lang-pill ${lang === "zh" ? "is-active" : ""}`}
					>
						中
					</a>
					<a
						href={langHref("ja")}
						data-lang="ja"
						class={`hearth-lang-pill ${lang === "ja" ? "is-active" : ""}`}
					>
						日
					</a>
				</div>
			</div>
		</nav>

		<!-- Page content -->
		<main class="pt-[82px] sm:pt-[92px]">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="hearth-footer">
			<div class="hearth-footer-row">
				<span class="font-ui font-semibold tracking-[-0.01em] text-[1.05rem]">
					<span class="hearth-logo-main">{brand.primary}</span>
					{brand.secondary ? <span class="hearth-logo-accent ml-1">{brand.secondary}</span> : null}
				</span>
				<span class={footerMetaClass}>
					{productData.site.hostLabel} &nbsp;·&nbsp; {t(lang, "footer.tagline")}
				</span>
			</div>
			<div class="hearth-footer-links">
				<a href={docs} class="hearth-footer-link">{t(lang, "footer.docs")}</a>
				<a href={changelogUrl} target="_blank" rel="noopener noreferrer" class="hearth-footer-link">
					{t(lang, "footer.changelog")}
				</a>
				<a href={issuesUrl} target="_blank" rel="noopener noreferrer" class="hearth-footer-link">
					{t(lang, "footer.issues")}
				</a>
				<a href={licenseUrl} target="_blank" rel="noopener noreferrer" class="hearth-footer-link">
					{t(lang, "footer.license")}
				</a>
			</div>
		</footer>
		<script is:inline>
			(() => {
				const normalizeLang = (value) => {
					if (!value) return null;
					const code = String(value).toLowerCase();
					if (code.startsWith("zh")) return "zh";
					if (code.startsWith("ja")) return "ja";
					if (code.startsWith("en")) return "en";
					return null;
				};

				const LANG_PREF_KEY = "hearth-lang";
				const currentLang = normalizeLang(document.documentElement.lang) ?? "en";
				const currentPath = window.location.pathname.replace(/\/+$/, "") || "/";
				const isEnEntryPoint = currentLang === "en" && (currentPath === "/" || currentPath === "/docs");

				const mapTargetPath = (basePath, preferredLang) => {
					if (preferredLang === "en") return basePath;
					if (basePath === "/docs") return `/${preferredLang}/docs`;
					return `/${preferredLang}`;
				};

				if (isEnEntryPoint) {
					let preferredLang = null;
					try {
						preferredLang = normalizeLang(localStorage.getItem(LANG_PREF_KEY));
					} catch {}

					if (!preferredLang) {
						const browserLangs =
							Array.isArray(navigator.languages) && navigator.languages.length > 0
								? navigator.languages
								: [navigator.language];
						for (const browserLang of browserLangs) {
							const hit = normalizeLang(browserLang);
							if (hit === "zh" || hit === "ja") {
								preferredLang = hit;
								break;
							}
						}
					}

					if (preferredLang && preferredLang !== "en") {
						const targetPath = mapTargetPath(currentPath, preferredLang);
						if (targetPath !== currentPath) {
							window.location.replace(`${targetPath}${window.location.search}${window.location.hash}`);
							return;
						}
					}
				}

				document.querySelectorAll(".hearth-lang-pill[data-lang]").forEach((pill) => {
					pill.addEventListener(
						"click",
						() => {
							const selected = normalizeLang(pill.getAttribute("data-lang"));
							if (!selected) return;
							try {
								localStorage.setItem(LANG_PREF_KEY, selected);
							} catch {}
						},
						{ passive: true },
					);
				});

				if (window.__hearthRevealInit) return;
				window.__hearthRevealInit = true;
				const topbar = document.querySelector(".hearth-topbar");

				const syncTopbar = () => {
					if (!topbar) return;
					topbar.classList.toggle("is-condensed", window.scrollY > 20);
				};

				syncTopbar();

				if (topbar) {
					let ticking = false;
					window.addEventListener(
						"scroll",
						() => {
							if (ticking) return;
							ticking = true;
							window.requestAnimationFrame(() => {
								syncTopbar();
								ticking = false;
							});
						},
						{ passive: true },
					);
				}

				const targets = document.querySelectorAll("[data-reveal]");
				if (!targets.length) return;

				const reveal = (el) => el.classList.add("is-visible");
				if (!("IntersectionObserver" in window)) {
					targets.forEach((el) => reveal(el));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							reveal(entry.target);
							observer.unobserve(entry.target);
						});
					},
					{ threshold: 0.01, rootMargin: "0px 0px -4% 0px" },
				);
				targets.forEach((el) => observer.observe(el));
			})();
		</script>
	</body>
</html>
