---
import { t, type Lang } from '../../i18n/utils'
import {
  DEFAULT_PREVIEW_FILE,
  DEFAULT_PREVIEW_FLAVOR,
  DEFAULT_PREVIEW_THEME,
  getPreviewRootStyle,
  previewFlavorTabs,
  previewTabs,
  previewThemeStateByFlavor,
  previewThemeTabs,
  renderPreviewState,
} from '../../lib/codePreview'

interface Props {
  lang: Lang
  compact?: boolean
}

const { lang, compact = false } = Astro.props

function escapeJsonForScript(value: unknown): string {
  return JSON.stringify(value).replace(/</g, '\\u003c')
}

const previewRootStyle = getPreviewRootStyle(DEFAULT_PREVIEW_FLAVOR, DEFAULT_PREVIEW_THEME)
const previewThemeJson = escapeJsonForScript(previewThemeStateByFlavor)
const initialPreviewHtml = await renderPreviewState(DEFAULT_PREVIEW_FILE, DEFAULT_PREVIEW_FLAVOR, DEFAULT_PREVIEW_THEME)
const initialThemeLabel = previewThemeStateByFlavor[DEFAULT_PREVIEW_FLAVOR][DEFAULT_PREVIEW_THEME].label
const previewDataEndpoint = '/code-preview-data.json'
---

{
  compact ? (
    <div
      class="code-preview-root"
      data-code-preview
      data-auto-carousel="true"
      data-preview-endpoint={previewDataEndpoint}
      data-default-file={DEFAULT_PREVIEW_FILE}
      data-default-flavor={DEFAULT_PREVIEW_FLAVOR}
      data-default-theme={DEFAULT_PREVIEW_THEME}
      style={previewRootStyle}
    >
      <script type="application/json" data-preview-themes set:html={previewThemeJson}></script>

      <div class="preview-stage preview-stage--compact overflow-hidden">
        <div class="preview-toolbar px-2.5 sm:px-3 py-2.5 sm:py-3">
          <div class="flex overflow-x-auto whitespace-nowrap gap-2" data-preview-tabs>
            {previewTabs.map(({ key, label }) => (
              <button
                type="button"
                data-file-tab={key}
                class={`preview-tab hearth-tab font-ui text-[12px] sm:text-[12.5px] px-3 sm:px-3.5 py-2 ${key === DEFAULT_PREVIEW_FILE ? 'is-active' : ''}`}
              >
                {label}
              </button>
            ))}
          </div>
          <div class="preview-controls mt-2.5 flex flex-wrap items-center gap-2 sm:gap-2.5">
            <div class="flavor-switch inline-flex flex-wrap gap-1 rounded-full border p-1">
              {previewFlavorTabs.map(({ key, label, description }) => (
                <button
                  type="button"
                  data-flavor-tab={key}
                  title={description}
                  class={`flavor-tab ${key === DEFAULT_PREVIEW_FLAVOR ? 'is-active' : ''}`}
                >
                  {label}
                </button>
              ))}
            </div>
            <div class="theme-switch inline-flex gap-1 rounded-full border p-1">
              {previewThemeTabs.map(({ key, label }) => (
                <button type="button" data-theme-tab={key} class={`theme-tab ${key === DEFAULT_PREVIEW_THEME ? 'is-active' : ''}`}>{label}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="preview-display preview-theme-panel" data-preview-display>
          <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5" data-preview-theme-label>
            {initialThemeLabel}
          </div>
          <div
            class="preview-content overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
            data-preview-content
            set:html={initialPreviewHtml}
          />
        </div>
      </div>
    </div>
  ) : (
    <section class="hearth-section pt-6 sm:pt-8 pb-12 sm:pb-16" data-reveal>
      <div class="hearth-shell">
        <div class="hearth-intro">
          <p class="hearth-kicker mb-5 flex items-center gap-3">
            {t(lang, 'preview.label')}
            <span class="hearth-line"></span>
          </p>
        </div>

        <div
          class="code-preview-root preview-stage overflow-hidden"
          data-code-preview
          data-preview-endpoint={previewDataEndpoint}
          data-default-file={DEFAULT_PREVIEW_FILE}
          data-default-flavor={DEFAULT_PREVIEW_FLAVOR}
          data-default-theme={DEFAULT_PREVIEW_THEME}
          style={previewRootStyle}
        >
          <script type="application/json" data-preview-themes set:html={previewThemeJson}></script>

          <div class="preview-toolbar px-2.5 sm:px-3 py-2.5 sm:py-3">
            <div class="flex overflow-x-auto whitespace-nowrap gap-2" data-preview-tabs>
              {previewTabs.map(({ key, label }) => (
                <button
                  type="button"
                  data-file-tab={key}
                  class={`preview-tab hearth-tab font-ui text-[12px] sm:text-[12.5px] px-3 sm:px-3.5 py-2 ${key === DEFAULT_PREVIEW_FILE ? 'is-active' : ''}`}
                >
                  {label}
                </button>
              ))}
            </div>
            <div class="preview-controls mt-2.5 flex flex-wrap items-center gap-2 sm:gap-2.5">
              <div class="flavor-switch inline-flex flex-wrap gap-1 rounded-full border p-1">
                {previewFlavorTabs.map(({ key, label, description }) => (
                  <button
                    type="button"
                    data-flavor-tab={key}
                    title={description}
                    class={`flavor-tab ${key === DEFAULT_PREVIEW_FLAVOR ? 'is-active' : ''}`}
                  >
                    {label}
                  </button>
                ))}
              </div>
              <div class="theme-switch inline-flex gap-1 rounded-full border p-1">
                {previewThemeTabs.map(({ key, label }) => (
                  <button type="button" data-theme-tab={key} class={`theme-tab ${key === DEFAULT_PREVIEW_THEME ? 'is-active' : ''}`}>{label}</button>
                ))}
              </div>
            </div>
          </div>

          <div class="preview-display preview-theme-panel" data-preview-display>
            <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5" data-preview-theme-label>
              {initialThemeLabel}
            </div>
            <div
              class="preview-content overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
              data-preview-content
              set:html={initialPreviewHtml}
            />
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .code-preview-root {
    position: relative;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 94%, transparent);
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(180deg, var(--hearth-preview-shell-grad-start), var(--hearth-preview-shell-grad-end));
    box-shadow:
      0 48px 90px var(--hearth-preview-shell-shadow-deep),
      0 14px 28px var(--hearth-preview-shell-shadow-mid),
      0 0 0 1px color-mix(in srgb, var(--hearth-paper-grid-soft) 30%, transparent),
      inset 0 1px 0 var(--hearth-preview-shell-edge);
  }

  .code-preview-root::before {
    content: "";
    position: absolute;
    inset: 0.65rem;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 62%, transparent);
    pointer-events: none;
    opacity: 0.72;
  }

  .preview-stage {
    background: linear-gradient(180deg, var(--hearth-preview-stage-grad-start), var(--hearth-preview-stage-grad-end));
    box-shadow:
      0 20px 36px var(--hearth-shadow-016),
      inset 0 1px 0 color-mix(in srgb, var(--hearth-paper-grid-soft) 38%, transparent);
  }

  .preview-stage--compact {
    box-shadow: none;
  }

  .preview-toolbar {
    background: var(--preview-toolbar-bg);
    border-bottom: 1px solid var(--preview-toolbar-border);
    transition:
      background-color 260ms var(--hearth-ease),
      border-color 260ms var(--hearth-ease);
  }

  .preview-tab {
    position: relative;
    color: var(--preview-tab-color);
    background: transparent;
    border: none;
    border-radius: 0;
    font-weight: 560;
    line-height: 1;
  }

  .preview-tab::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08rem;
    height: 1.5px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.45);
    transform-origin: center;
    transition:
      opacity 220ms var(--hearth-ease),
      transform 220ms var(--hearth-ease);
  }

  .preview-tab:hover {
    color: var(--preview-tab-hover-color);
  }

  .preview-tab:hover::after {
    opacity: 0.45;
    transform: scaleX(1);
  }

  .preview-tab.is-active {
    color: var(--preview-tab-active-color);
    text-shadow: 0 0 10px var(--hearth-preview-tab-active-shadow);
  }

  .preview-tab.is-active::after {
    opacity: 0.92;
    transform: scaleX(1);
  }

  .flavor-switch,
  .theme-switch {
    border-color: var(--hearth-preview-switch-border);
    background: color-mix(in srgb, var(--preview-toolbar-bg) 84%, transparent);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--preview-tab-active-color) 6%, transparent);
  }

  .flavor-tab,
  .theme-tab {
    border: none;
    border-radius: 9999px;
    background: transparent;
    color: var(--preview-switch-color);
    font-family: var(--font-ui);
    line-height: 1;
    font-weight: 600;
    transition: color 220ms var(--hearth-ease), background-color 220ms var(--hearth-ease);
  }

  .flavor-tab {
    padding: 0.36rem 0.82rem;
    font-size: 10.5px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .theme-tab {
    padding: 0.3rem 0.72rem;
    font-size: 11px;
    letter-spacing: 0.02em;
  }

  .flavor-tab:hover,
  .theme-tab:hover {
    color: var(--preview-switch-hover-color);
  }

  .flavor-tab.is-active,
  .theme-tab.is-active {
    color: var(--preview-switch-active-color);
    background: var(--hearth-preview-switch-active-bg);
    box-shadow: inset 0 0 0 1px var(--hearth-preview-switch-active-ring);
  }

  .preview-display {
    position: relative;
    min-height: 380px;
    background: var(--preview-panel-bg);
    transition: background-color 260ms var(--hearth-ease);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--preview-strip-color) 5%, transparent);
  }

  .theme-strip {
    background: var(--preview-strip-bg);
    color: var(--preview-strip-color);
    border-bottom: 1px solid var(--preview-strip-border-color);
    transition:
      background-color 260ms var(--hearth-ease),
      color 220ms var(--hearth-ease),
      border-color 260ms var(--hearth-ease);
  }

  .preview-content {
    position: relative;
    will-change: opacity, filter;
  }

  .preview-content.is-refreshing {
    animation: preview-content-refresh 420ms var(--hearth-ease);
  }

  .preview-content::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--preview-strip-color) 12%, transparent) 0%,
      transparent 34%
    );
  }

  .preview-content.is-refreshing::after {
    animation: preview-content-sheen 420ms var(--hearth-ease);
  }

  .preview-stage--compact .preview-display {
    min-height: clamp(390px, 53svh, 540px);
  }

  .preview-stage--compact .shiki-wrap {
    max-height: clamp(340px, 48svh, 480px);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 86%, transparent 100%);
    mask-image: linear-gradient(180deg, black 0%, black 86%, transparent 100%);
    scrollbar-width: none;
  }

  .preview-stage--compact .shiki-wrap::-webkit-scrollbar {
    width: 0;
    height: 0;
    background: transparent;
  }

  @media (max-width: 860px) {
    .code-preview-root {
      width: min(92vw, 520px);
      margin-inline: auto;
      border-radius: 16px;
      box-shadow:
        0 26px 48px var(--hearth-preview-mobile-shadow-deep),
        0 8px 18px var(--hearth-shadow-024),
        inset 0 1px 0 var(--hearth-paper-grid-soft);
    }

    .preview-toolbar {
      padding-block: 0.48rem;
      padding-inline: 0.54rem;
    }

    .preview-tab {
      font-size: 11px;
    }

    .flavor-tab {
      font-size: 9.8px;
      padding: 0.28rem 0.62rem;
    }

    .theme-tab {
      font-size: 10px;
      padding: 0.26rem 0.56rem;
    }

    .preview-stage--compact .preview-display {
      min-height: clamp(250px, 34svh, 340px);
    }

    .preview-stage--compact .shiki-wrap {
      max-height: clamp(180px, 27svh, 260px);
      -webkit-mask-image: linear-gradient(180deg, black 0%, black 84%, transparent 100%);
      mask-image: linear-gradient(180deg, black 0%, black 84%, transparent 100%);
    }

    .shiki-wrap :global(code) {
      font-size: 12px;
      line-height: 1.72;
    }
  }

  @media (max-width: 480px) {
    .code-preview-root {
      width: min(94vw, 430px);
      border-radius: 14px;
    }

    .preview-toolbar {
      padding-inline: 0.46rem;
    }

    .preview-tab {
      font-size: 10px;
      padding-inline: 0.52rem;
      padding-block: 0.42rem;
    }

    .flavor-tab {
      font-size: 9px;
      padding: 0.24rem 0.5rem;
    }

    .theme-tab {
      font-size: 9.5px;
      padding: 0.24rem 0.48rem;
    }

    .preview-stage--compact .preview-display {
      min-height: clamp(220px, 31svh, 300px);
    }

    .preview-stage--compact .shiki-wrap {
      max-height: clamp(150px, 23svh, 220px);
    }

    .shiki-wrap :global(code) {
      font-size: 11px;
      line-height: 1.62;
    }
  }

  .shiki-wrap :global(pre) {
    background: transparent !important;
    margin: 0;
    padding: 0;
  }

  .shiki-wrap :global(code) {
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.82;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(html:lang(zh)) .shiki-wrap :global(code),
  :global(html:lang(ja)) .shiki-wrap :global(code) {
    font-family:
      "JetBrains Mono",
      "Cascadia Mono",
      "Cascadia Code",
      "Consolas",
      "Sarasa Mono SC",
      "Sarasa Mono J",
      "Noto Sans Mono CJK SC",
      "Noto Sans Mono CJK JP",
      "Microsoft YaHei UI",
      "Yu Gothic UI",
      monospace;
    line-height: 1.92;
  }

  @keyframes preview-content-refresh {
    0% {
      opacity: 0.22;
      filter: blur(1.2px) saturate(0.9);
    }

    55% {
      opacity: 0.8;
      filter: blur(0.2px) saturate(0.97);
    }

    100% {
      opacity: 1;
      filter: saturate(1);
    }
  }

  @keyframes preview-content-sheen {
    0% {
      opacity: 0;
    }

    18% {
      opacity: 0.75;
    }

    100% {
      opacity: 0;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-code-preview]').forEach(root => {
    if (root.dataset.previewReady === 'true') return
    root.dataset.previewReady = 'true'

    const fileTabs = root.querySelectorAll<HTMLElement>('[data-file-tab]')
    const flavorTabs = root.querySelectorAll<HTMLElement>('[data-flavor-tab]')
    const themeTabs = root.querySelectorAll<HTMLElement>('[data-theme-tab]')
    const previewDisplay = root.querySelector<HTMLElement>('[data-preview-display]')
    const previewContent = root.querySelector<HTMLElement>('[data-preview-content]')
    const themeLabel = root.querySelector<HTMLElement>('[data-preview-theme-label]')
    const themeScript = root.querySelector<HTMLScriptElement>('[data-preview-themes]')
    const dataEndpoint = root.dataset.previewEndpoint || '/code-preview-data.json'

    const themeStateMap = (() => {
      try {
        return JSON.parse(themeScript?.textContent || '{}') as Record<string, Record<string, Record<string, string | boolean>>>
      } catch {
        return {}
      }
    })()

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const fileOrder = Array.from(fileTabs).map(tab => tab.dataset.fileTab).filter(Boolean) as string[]
    const flavorOrder = Array.from(flavorTabs).map(tab => tab.dataset.flavorTab).filter(Boolean) as string[]
    const themeOrder = Array.from(themeTabs).map(tab => tab.dataset.themeTab).filter(Boolean) as string[]

    let currentFile = root.dataset.defaultFile || fileOrder[0] || 'ts'
    let currentFlavor = root.dataset.defaultFlavor || flavorOrder[0] || 'hearth'
    let currentTheme = root.dataset.defaultTheme || themeOrder[0] || 'dark'
    let currentRenderKey = `${currentFile}:${currentFlavor}:${currentTheme}`
    let renderedMap: Record<string, Record<string, Record<string, string>>> = {}
    let hasFullPreviewData = false
    let previewDataPromise: Promise<Record<string, Record<string, Record<string, string>>>> | null = null
    let lastInteractionAt = 0
    const warmupTimer = window.setTimeout(() => {
      void ensureRenderedMap()
    }, 1200)
    let fileTimer: number | undefined
    let themeTimer: number | undefined

    const INTERACTION_PAUSE_MS = 12000
    const FILE_INTERVAL_MS = 6800
    const THEME_INTERVAL_MS = 17000

    if (previewContent?.innerHTML) {
      renderedMap[currentFile] = {
        [currentFlavor]: {
          [currentTheme]: previewContent.innerHTML,
        },
      }
    }

    const markInteraction = () => {
      lastInteractionAt = Date.now()
    }

    const ensureRenderedMap = async () => {
      if (hasFullPreviewData) return renderedMap
      if (!previewDataPromise) {
        previewDataPromise = fetch(dataEndpoint, {
          headers: { accept: 'application/json' },
        })
          .then(async response => {
            if (!response.ok) {
              throw new Error(`HTTP ${response.status}`)
            }
            const payload = await response.json() as { rendered?: Record<string, Record<string, Record<string, string>>> }
            if (!payload?.rendered) {
              throw new Error('Missing rendered preview payload.')
            }
            renderedMap = payload.rendered
            hasFullPreviewData = true
            return renderedMap
          })
          .catch(error => {
            previewDataPromise = null
            console.error('CodePreview: failed to load preview payload.', error)
            return renderedMap
          })
      }
      return previewDataPromise
    }

    const triggerRefresh = (el: HTMLElement | null, animate = true) => {
      if (!el || !animate || prefersReducedMotion) return
      el.classList.remove('is-refreshing')
      window.requestAnimationFrame(() => {
        el.classList.add('is-refreshing')
        window.setTimeout(() => el.classList.remove('is-refreshing'), 460)
      })
    }

    const renderActive = async (animate = true) => {
      const targetFile = currentFile
      const targetFlavor = currentFlavor
      const targetTheme = currentTheme
      let nextHtml = renderedMap?.[targetFile]?.[targetFlavor]?.[targetTheme]

      if (!nextHtml) {
        await ensureRenderedMap()
        nextHtml = renderedMap?.[targetFile]?.[targetFlavor]?.[targetTheme]
      }

      if (!nextHtml || targetFile !== currentFile || targetFlavor !== currentFlavor || targetTheme !== currentTheme) {
        return false
      }

      const nextRenderKey = `${targetFile}:${targetFlavor}:${targetTheme}`
      if (previewContent && currentRenderKey !== nextRenderKey) {
        previewContent.innerHTML = nextHtml
      }
      currentRenderKey = nextRenderKey
      triggerRefresh(previewContent, animate)
      return true
    }

    const applyThemeUi = (flavorKey: string, themeKey: string) => {
      const ui = themeStateMap?.[flavorKey]?.[themeKey]
      if (!ui) return
      if (typeof ui.toolbarBg === 'string') root.style.setProperty('--preview-toolbar-bg', ui.toolbarBg)
      if (typeof ui.toolbarBorder === 'string') root.style.setProperty('--preview-toolbar-border', ui.toolbarBorder)
      if (typeof ui.tabColor === 'string') root.style.setProperty('--preview-tab-color', ui.tabColor)
      if (typeof ui.tabHoverColor === 'string') root.style.setProperty('--preview-tab-hover-color', ui.tabHoverColor)
      if (typeof ui.tabActiveColor === 'string') root.style.setProperty('--preview-tab-active-color', ui.tabActiveColor)
      if (typeof ui.switchColor === 'string') root.style.setProperty('--preview-switch-color', ui.switchColor)
      if (typeof ui.switchHoverColor === 'string') root.style.setProperty('--preview-switch-hover-color', ui.switchHoverColor)
      if (typeof ui.switchActiveColor === 'string') root.style.setProperty('--preview-switch-active-color', ui.switchActiveColor)
      if (typeof ui.panelBg === 'string') root.style.setProperty('--preview-panel-bg', ui.panelBg)
      if (typeof ui.stripBg === 'string') root.style.setProperty('--preview-strip-bg', ui.stripBg)
      if (typeof ui.stripColor === 'string') root.style.setProperty('--preview-strip-color', ui.stripColor)
      if (typeof ui.stripBorder === 'string') root.style.setProperty('--preview-strip-border-color', ui.stripBorder)

      if (themeLabel && typeof ui.label === 'string') {
        themeLabel.textContent = ui.label
      }

      if (previewDisplay) {
        previewDisplay.classList.toggle('hearth-paper', Boolean(ui.paper))
      }
    }

    const syncThemeTabs = () => {
      themeTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.themeTab === currentTheme)
      })
    }

    const syncFlavorTabs = () => {
      flavorTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.flavorTab === currentFlavor)
      })
    }

    const syncFileTabs = () => {
      fileTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.fileTab === currentFile)
      })
    }

    const setTheme = async (themeKey: string | null, animate = true) => {
      if (!themeKey) return
      const previousTheme = currentTheme
      currentTheme = themeKey
      applyThemeUi(currentFlavor, themeKey)
      syncThemeTabs()

      const didRender = await renderActive(animate)
      if (!didRender && currentTheme === themeKey) {
        currentTheme = previousTheme
        applyThemeUi(currentFlavor, previousTheme)
        syncThemeTabs()
      }
    }

    const setFlavor = async (flavorKey: string | null, animate = true) => {
      if (!flavorKey) return
      const previousFlavor = currentFlavor
      currentFlavor = flavorKey
      applyThemeUi(flavorKey, currentTheme)
      syncFlavorTabs()

      const didRender = await renderActive(animate)
      if (!didRender && currentFlavor === flavorKey) {
        currentFlavor = previousFlavor
        applyThemeUi(previousFlavor, currentTheme)
        syncFlavorTabs()
      }
    }

    const setFile = async (fileKey: string | null, animate = true) => {
      if (!fileKey) return
      const previousFile = currentFile
      currentFile = fileKey
      syncFileTabs()

      const didRender = await renderActive(animate)
      if (!didRender && currentFile === fileKey) {
        currentFile = previousFile
        syncFileTabs()
      }
    }

    const applyPreset = async (flavorKey: string | null, themeKey: string | null, animate = true) => {
      const nextFlavor = flavorKey || currentFlavor
      const nextTheme = themeKey || currentTheme
      const previousFlavor = currentFlavor
      const previousTheme = currentTheme

      currentFlavor = nextFlavor
      currentTheme = nextTheme
      applyThemeUi(nextFlavor, nextTheme)
      syncFlavorTabs()
      syncThemeTabs()

      const didRender = await renderActive(animate)
      if (!didRender) {
        currentFlavor = previousFlavor
        currentTheme = previousTheme
        applyThemeUi(previousFlavor, previousTheme)
        syncFlavorTabs()
        syncThemeTabs()
      }
    }

    const nextFrom = (items: string[], current: string) => {
      if (!items.length) return current
      const idx = items.indexOf(current)
      return items[(idx + 1 + items.length) % items.length]
    }

    const setupAutoCarousel = () => {
      if (root.dataset.autoCarousel !== 'true' || prefersReducedMotion) return
      if (!window.matchMedia('(min-width: 861px)').matches) return
      if (fileOrder.length < 2 && themeOrder.length < 2) return

      fileTimer = window.setInterval(() => {
        if (Date.now() - lastInteractionAt < INTERACTION_PAUSE_MS) return
        const nextFile = nextFrom(fileOrder, currentFile)
        void setFile(nextFile, true)
      }, FILE_INTERVAL_MS)

      themeTimer = window.setInterval(() => {
        if (Date.now() - lastInteractionAt < INTERACTION_PAUSE_MS) return
        const nextTheme = nextFrom(themeOrder, currentTheme)
        void setTheme(nextTheme, true)
      }, THEME_INTERVAL_MS)
    }

    fileTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        void setFile(tab.dataset.fileTab ?? null, true)
      })
    })

    flavorTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        void setFlavor(tab.dataset.flavorTab ?? null, true)
      })
    })

    themeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        void setTheme(tab.dataset.themeTab ?? null, true)
      })
    })

    root.addEventListener('pointerenter', markInteraction, { passive: true })
    root.addEventListener('focusin', markInteraction, { passive: true })

    const handleExternalPreset = (event: Event) => {
      const detail = (event as CustomEvent<{ flavorId?: string; themeId?: string }>).detail || {}
      markInteraction()
      void applyPreset(detail.flavorId ?? null, detail.themeId ?? null, true)
    }

    window.addEventListener('theme-fit-preview', handleExternalPreset as EventListener)

    applyThemeUi(currentFlavor, currentTheme)
    syncFileTabs()
    syncFlavorTabs()
    syncThemeTabs()
    setupAutoCarousel()

    window.addEventListener('beforeunload', () => {
      window.clearTimeout(warmupTimer)
      if (fileTimer) window.clearInterval(fileTimer)
      if (themeTimer) window.clearInterval(themeTimer)
      window.removeEventListener('theme-fit-preview', handleExternalPreset as EventListener)
    })
  })
</script>
