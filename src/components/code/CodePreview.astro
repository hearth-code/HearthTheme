---
import { t, type Lang } from '../../i18n/utils'
import { codeToHtml } from 'shiki'
import { tokens } from '../../data/tokens'

interface Props {
  lang: Lang
  compact?: boolean
}

const { lang, compact = false } = Astro.props
const d = tokens.dark
const s = tokens.darkSoft
const l = tokens.light
const ls = tokens.lightSoft

const HearthDark = {
  name: 'Hearth Dark',
  type: 'dark' as const,
  colors: {
    'editor.background': d.bg,
    'editor.foreground': d.fg,
  },
  tokenColors: [
    { scope: ['comment'],                                               settings: { foreground: d.comment,  fontStyle: 'italic' } },
    { scope: ['keyword', 'storage.type', 'storage.modifier'],          settings: { foreground: d.keyword } },
    { scope: ['entity.name.function', 'support.function'],             settings: { foreground: d.fn } },
    { scope: ['string', 'string.quoted', 'string.template'],           settings: { foreground: d.string } },
    { scope: ['constant.numeric'],                                      settings: { foreground: d.number } },
    { scope: ['entity.name.type', 'entity.name.class', 'support.type'],settings: { foreground: d.type, fontStyle: 'italic' } },
    { scope: ['variable', 'variable.other'],                            settings: { foreground: d.variable } },
    { scope: ['keyword.operator'],                                      settings: { foreground: d.operator } },
    { scope: ['entity.name.tag', 'punctuation.definition.tag'],        settings: { foreground: d.keyword } },
    { scope: ['entity.other.attribute-name'],                           settings: { foreground: d.type } },
    { scope: ['support.type.property-name', 'variable.css'],           settings: { foreground: d.fn } },
  ],
}

const HearthLight = {
  name: 'Hearth Light',
  type: 'light' as const,
  colors: {
    'editor.background': l.bg,
    'editor.foreground': l.fg,
  },
  tokenColors: [
    { scope: ['comment'],                                               settings: { foreground: l.comment,  fontStyle: 'italic' } },
    { scope: ['keyword', 'storage.type', 'storage.modifier'],          settings: { foreground: l.keyword } },
    { scope: ['entity.name.function', 'support.function'],             settings: { foreground: l.fn } },
    { scope: ['string', 'string.quoted', 'string.template'],           settings: { foreground: l.string } },
    { scope: ['constant.numeric'],                                      settings: { foreground: l.number } },
    { scope: ['entity.name.type', 'entity.name.class', 'support.type'],settings: { foreground: l.type, fontStyle: 'italic' } },
    { scope: ['variable', 'variable.other'],                            settings: { foreground: l.variable } },
    { scope: ['keyword.operator'],                                      settings: { foreground: l.operator } },
    { scope: ['entity.name.tag', 'punctuation.definition.tag'],        settings: { foreground: l.keyword } },
    { scope: ['entity.other.attribute-name'],                           settings: { foreground: l.type } },
    { scope: ['support.type.property-name', 'variable.css'],           settings: { foreground: l.fn } },
  ],
}

const HearthLightSoft = {
  name: 'Hearth Light Soft',
  type: 'light' as const,
  colors: {
    'editor.background': ls.bg,
    'editor.foreground': ls.fg,
  },
  tokenColors: [
    { scope: ['comment'],                                               settings: { foreground: ls.comment,  fontStyle: 'italic' } },
    { scope: ['keyword', 'storage.type', 'storage.modifier'],          settings: { foreground: ls.keyword } },
    { scope: ['entity.name.function', 'support.function'],             settings: { foreground: ls.fn } },
    { scope: ['string', 'string.quoted', 'string.template'],           settings: { foreground: ls.string } },
    { scope: ['constant.numeric'],                                      settings: { foreground: ls.number } },
    { scope: ['entity.name.type', 'entity.name.class', 'support.type'],settings: { foreground: ls.type, fontStyle: 'italic' } },
    { scope: ['variable', 'variable.other'],                            settings: { foreground: ls.variable } },
    { scope: ['keyword.operator'],                                      settings: { foreground: ls.operator } },
    { scope: ['entity.name.tag', 'punctuation.definition.tag'],        settings: { foreground: ls.keyword } },
    { scope: ['entity.other.attribute-name'],                           settings: { foreground: ls.type } },
    { scope: ['support.type.property-name', 'variable.css'],           settings: { foreground: ls.fn } },
  ],
}

const HearthDarkSoft = {
  name: 'Hearth Dark Soft',
  type: 'dark' as const,
  colors: {
    'editor.background': s.bg,
    'editor.foreground': s.fg,
  },
  tokenColors: [
    { scope: ['comment'],                                               settings: { foreground: s.comment,  fontStyle: 'italic' } },
    { scope: ['keyword', 'storage.type', 'storage.modifier'],          settings: { foreground: s.keyword } },
    { scope: ['entity.name.function', 'support.function'],             settings: { foreground: s.fn } },
    { scope: ['string', 'string.quoted', 'string.template'],           settings: { foreground: s.string } },
    { scope: ['constant.numeric'],                                      settings: { foreground: s.number } },
    { scope: ['entity.name.type', 'entity.name.class', 'support.type'],settings: { foreground: s.type, fontStyle: 'italic' } },
    { scope: ['variable', 'variable.other'],                            settings: { foreground: s.variable } },
    { scope: ['keyword.operator'],                                      settings: { foreground: s.operator } },
    { scope: ['entity.name.tag', 'punctuation.definition.tag'],        settings: { foreground: s.keyword } },
    { scope: ['entity.other.attribute-name'],                           settings: { foreground: s.type } },
    { scope: ['support.type.property-name', 'variable.css'],           settings: { foreground: s.fn } },
  ],
}

const samples = {
  ts: `// async data fetching with full type safety
import { createContext, useContext } from 'react'

interface ApiResponse<T> {
  data: T
  status: number
  ok: boolean
}

async function request<T>(
  url: string,
  options?: RequestInit
): Promise<ApiResponse<T>> {
  const res = await fetch(url, options)
  const data = await res.json() as T
  return { data, status: res.status, ok: res.ok }
}

const BASE = 'https://api.hearthcode.dev'
const TIMEOUT = 5_000`,

  py: `# dataclass-based connection pool
from dataclasses import dataclass, field
from typing import Optional, ClassVar
import asyncio

@dataclass
class Connection:
    host: str
    port: int = 5432
    timeout: float = 30.0

class Pool:
    MAX: ClassVar[int] = 20

    def __init__(self, dsn: str):
        self.dsn = dsn
        self._pool: list[Connection] = []

    async def acquire(self) -> Optional[Connection]:
        if not self._pool:
            return None
        return self._pool.pop()`,

  go: `// HTTP server with graceful shutdown
package main

import (
  "context"
  "net/http"
  "time"
)

type Server struct {
  addr    string
  timeout time.Duration
  mux     *http.ServeMux
}

func New(addr string) *Server {
  return &Server{
    addr:    addr,
    timeout: 10 * time.Second,
    mux:     http.NewServeMux(),
  }
}`,

  rs: `// typed parser with Result and Option
use std::collections::HashMap;

#[derive(Debug, Clone)]
struct Config {
    host: String,
    port: u16,
}

fn load_config(env: &HashMap<String, String>) -> Result<Config, String> {
    let host = env.get("HOST").cloned().unwrap_or_else(|| "127.0.0.1".into());
    let port = env
        .get("PORT")
        .and_then(|v| v.parse::<u16>().ok())
        .unwrap_or(8080);
    Ok(Config { host, port })
}`,

  java: `// immutable service model with records
import java.time.Duration;
import java.util.List;

public final class HearthService {
  private final String endpoint;
  private final Duration timeout;

  public HearthService(String endpoint) {
    this.endpoint = endpoint;
    this.timeout = Duration.ofSeconds(5);
  }

  public record Result<T>(T data, int status) {}
}`,

  bash: `#!/usr/bin/env bash
set -euo pipefail

APP_NAME="hearth"
BUILD_DIR="./dist"

echo "[\${APP_NAME}] cleaning old build"
rm -rf "\${BUILD_DIR}"

echo "[\${APP_NAME}] building site"
npm run build
`,

  html: `<!-- Hearth UI component -->
<style>
  :root {
    --HearthCode: var(--hearth-ember);
    --bg: var(--hearth-bg);
  }
  .card {
    background: var(--bg);
    border: 1px solid var(--HearthCode);
    border-radius: 8px;
    padding: 1.5rem;
  }
</style>

<div class="card">
  <h2>HearthCode</h2>
  <p>Code by Hearthlight</p>
</div>`,
}

const langMap: Record<string, string> = {
  ts:   'typescript',
  py:   'python',
  go:   'go',
  rs:   'rust',
  java: 'java',
  bash: 'bash',
  html: 'html',
}

const rendered: Record<string, { dark: string; soft: string; light: string; lightSoft: string }> = {}
for (const [key, code] of Object.entries(samples)) {
  const [dark, soft, light, lightSoft] = await Promise.all([
    codeToHtml(code, { lang: langMap[key], theme: HearthDark }),
    codeToHtml(code, { lang: langMap[key], theme: HearthDarkSoft }),
    codeToHtml(code, { lang: langMap[key], theme: HearthLight }),
    codeToHtml(code, { lang: langMap[key], theme: HearthLightSoft }),
  ])
  rendered[key] = { dark, soft, light, lightSoft }
}

const tabs = [
  { key: 'ts',   label: 'index.ts'   },
  { key: 'py',   label: 'main.py'    },
  { key: 'go',   label: 'server.go'  },
  { key: 'rs',   label: 'main.rs'    },
  { key: 'java', label: 'App.java'   },
  { key: 'bash', label: 'build.sh'   },
  { key: 'html', label: 'index.html' },
]
---

{
  compact ? (
    <div class="code-preview-root" data-code-preview data-auto-carousel="true">
      <div class="preview-stage preview-stage--compact overflow-hidden">
        <div class="preview-toolbar px-2.5 sm:px-3 py-2.5 sm:py-3" style={`background: ${d.sidebar}`}>
          <div class="flex overflow-x-auto whitespace-nowrap gap-2" data-preview-tabs>
            {tabs.map(({ key, label }) => (
              <button
                data-file-tab={key}
                class={`preview-tab hearth-tab font-ui text-[12px] sm:text-[12.5px] px-3 sm:px-3.5 py-2 ${key === 'ts' ? 'is-active' : ''}`}
              >
                {label}
              </button>
            ))}
          </div>
          <div class="theme-switch mt-2 sm:mt-2.5 inline-flex gap-1 rounded-full border p-1">
            <button data-theme-tab="dark" class="theme-tab is-active">Dark</button>
            <button data-theme-tab="soft" class="theme-tab">Dark Soft</button>
            <button data-theme-tab="light" class="theme-tab">Light</button>
            <button data-theme-tab="lightSoft" class="theme-tab">Light Soft</button>
          </div>
        </div>

        <div>
          {tabs.map(({ key }) => (
            <div
              class={`preview-file-panel ${key !== 'ts' ? 'hidden' : ''}`}
              data-file-panel={key}
            >
              <div class="preview-theme-panel" data-theme-panel="dark" style={`background: ${d.bg}`}>
                <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                  style={`background: ${d.sidebar}; color: ${d.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-dark)`}>
                  Hearth Dark
                </div>
                <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                  set:html={rendered[key].dark} />
              </div>

              <div class="preview-theme-panel hidden" data-theme-panel="soft" style={`background: ${s.bg}`}>
                <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                  style={`background: ${s.sidebar}; color: ${s.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-dark)`}>
                  Hearth Dark Soft
                </div>
                <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                  set:html={rendered[key].soft} />
              </div>

              <div class="preview-theme-panel hidden hearth-paper" data-theme-panel="light" style={`background: ${l.bg}`}>
                <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                  style={`background: ${l.sidebar}; color: ${l.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-light)`}>
                  Hearth Light
                </div>
                <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                  set:html={rendered[key].light} />
              </div>

              <div class="preview-theme-panel hidden hearth-paper" data-theme-panel="lightSoft" style={`background: ${ls.bg}`}>
                <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                  style={`background: ${ls.sidebar}; color: ${ls.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-light)`}>
                  Hearth Light Soft
                </div>
                <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                  set:html={rendered[key].lightSoft} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  ) : (
    <section class="hearth-section pt-6 sm:pt-8 pb-12 sm:pb-16" data-reveal>
      <div class="hearth-shell">
        <div class="hearth-intro">
          <p class="hearth-kicker mb-5 flex items-center gap-3">
            {t(lang, 'preview.label')}
            <span class="hearth-line"></span>
          </p>
        </div>

        <div class="code-preview-root preview-stage overflow-hidden" data-code-preview>
          <div class="preview-toolbar px-2.5 sm:px-3 py-2.5 sm:py-3" style={`background: ${d.sidebar}`}>
            <div class="flex overflow-x-auto whitespace-nowrap gap-2" data-preview-tabs>
              {tabs.map(({ key, label }) => (
                <button
                  data-file-tab={key}
                  class={`preview-tab hearth-tab font-ui text-[12px] sm:text-[12.5px] px-3 sm:px-3.5 py-2 ${key === 'ts' ? 'is-active' : ''}`}
                >
                  {label}
                </button>
              ))}
            </div>
            <div class="theme-switch mt-2 sm:mt-2.5 inline-flex gap-1 rounded-full border p-1">
              <button data-theme-tab="dark" class="theme-tab is-active">Dark</button>
              <button data-theme-tab="soft" class="theme-tab">Dark Soft</button>
              <button data-theme-tab="light" class="theme-tab">Light</button>
              <button data-theme-tab="lightSoft" class="theme-tab">Light Soft</button>
            </div>
          </div>

          <div>
            {tabs.map(({ key }) => (
              <div
                class={`preview-file-panel ${key !== 'ts' ? 'hidden' : ''}`}
                data-file-panel={key}
              >
                <div class="preview-theme-panel" data-theme-panel="dark" style={`background: ${d.bg}`}>
                  <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                    style={`background: ${d.sidebar}; color: ${d.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-dark)`}>
                    Hearth Dark
                  </div>
                  <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                    set:html={rendered[key].dark} />
                </div>

                <div class="preview-theme-panel hidden" data-theme-panel="soft" style={`background: ${s.bg}`}>
                  <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                    style={`background: ${s.sidebar}; color: ${s.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-dark)`}>
                    Hearth Dark Soft
                  </div>
                  <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                    set:html={rendered[key].soft} />
                </div>

                <div class="preview-theme-panel hidden hearth-paper" data-theme-panel="light" style={`background: ${l.bg}`}>
                  <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                    style={`background: ${l.sidebar}; color: ${l.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-light)`}>
                    Hearth Light
                  </div>
                  <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                    set:html={rendered[key].light} />
                </div>

                <div class="preview-theme-panel hidden hearth-paper" data-theme-panel="lightSoft" style={`background: ${ls.bg}`}>
                  <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5"
                    style={`background: ${ls.sidebar}; color: ${ls.comment}; border-bottom: 1px solid var(--hearth-preview-strip-border-light)`}>
                    Hearth Light Soft
                  </div>
                  <div class="overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
                    set:html={rendered[key].lightSoft} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .code-preview-root {
    border: none;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(180deg, var(--hearth-preview-shell-grad-start), var(--hearth-preview-shell-grad-end));
    box-shadow:
      0 48px 90px var(--hearth-preview-shell-shadow-deep),
      0 14px 28px var(--hearth-preview-shell-shadow-mid),
      inset 0 1px 0 var(--hearth-preview-shell-edge);
  }

  .preview-stage {
    background: linear-gradient(180deg, var(--hearth-preview-stage-grad-start), var(--hearth-preview-stage-grad-end));
    box-shadow: 0 20px 36px var(--hearth-shadow-016);
  }

  .preview-stage--compact {
    box-shadow: none;
  }

  .preview-toolbar {
    border-bottom: 1px solid var(--hearth-preview-strip-border-dark);
  }

  .preview-tab {
    position: relative;
    color: var(--hearth-muted);
    background: transparent;
    border: none;
    border-radius: 0;
    font-weight: 560;
    line-height: 1;
  }

  .preview-tab::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08rem;
    height: 1.5px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.45);
    transform-origin: center;
    transition:
      opacity 220ms var(--hearth-ease),
      transform 220ms var(--hearth-ease);
  }

  .preview-tab:hover {
    color: var(--hearth-fg);
  }

  .preview-tab:hover::after {
    opacity: 0.45;
    transform: scaleX(1);
  }

  .preview-tab.is-active {
    color: var(--hearth-brand-main);
    text-shadow: 0 0 10px var(--hearth-preview-tab-active-shadow);
  }

  .theme-switch {
    border-color: var(--hearth-preview-switch-border);
  }

  .preview-tab.is-active::after {
    opacity: 0.92;
    transform: scaleX(1);
  }

  .theme-tab {
    border: none;
    border-radius: 9999px;
    padding: 0.3rem 0.72rem;
    background: transparent;
    color: var(--hearth-muted);
    font-family: var(--font-ui);
    font-size: 11px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: color 220ms var(--hearth-ease), background-color 220ms var(--hearth-ease);
  }

  .theme-tab:hover {
    color: var(--hearth-fg);
  }

  .theme-tab.is-active {
    color: var(--hearth-brand-main);
    background: var(--hearth-preview-switch-active-bg);
    box-shadow: inset 0 0 0 1px var(--hearth-preview-switch-active-ring);
  }

  .preview-theme-panel {
    min-height: 380px;
    will-change: opacity, transform, filter;
  }

  .preview-file-panel {
    will-change: opacity, transform, filter;
  }

  .preview-file-panel.is-entering,
  .preview-theme-panel.is-entering {
    animation: preview-enter 620ms var(--hearth-ease);
  }

  .preview-stage--compact .preview-theme-panel {
    min-height: clamp(390px, 53svh, 540px);
  }

  .preview-stage--compact .shiki-wrap {
    max-height: clamp(340px, 48svh, 480px);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 86%, transparent 100%);
    mask-image: linear-gradient(180deg, black 0%, black 86%, transparent 100%);
    scrollbar-width: none;
  }

  .preview-stage--compact .shiki-wrap::-webkit-scrollbar {
    width: 0;
    height: 0;
    background: transparent;
  }

  @media (max-width: 860px) {
    .code-preview-root {
      width: min(92vw, 520px);
      margin-inline: auto;
      border-radius: 16px;
      box-shadow:
        0 26px 48px var(--hearth-preview-mobile-shadow-deep),
        0 8px 18px var(--hearth-shadow-024),
        inset 0 1px 0 var(--hearth-paper-grid-soft);
    }

    .preview-toolbar {
      padding-block: 0.48rem;
      padding-inline: 0.54rem;
    }

    .preview-tab {
      font-size: 11px;
    }

    .theme-tab {
      font-size: 10px;
      padding: 0.26rem 0.56rem;
    }

    .preview-stage--compact .preview-theme-panel {
      min-height: clamp(250px, 34svh, 340px);
    }

    .preview-stage--compact .shiki-wrap {
      max-height: clamp(180px, 27svh, 260px);
      -webkit-mask-image: linear-gradient(180deg, black 0%, black 84%, transparent 100%);
      mask-image: linear-gradient(180deg, black 0%, black 84%, transparent 100%);
    }

    .shiki-wrap :global(code) {
      font-size: 12px;
      line-height: 1.72;
    }
  }

  @media (max-width: 480px) {
    .code-preview-root {
      width: min(94vw, 430px);
      border-radius: 14px;
    }

    .preview-toolbar {
      padding-inline: 0.46rem;
    }

    .preview-tab {
      font-size: 10px;
      padding-inline: 0.52rem;
      padding-block: 0.42rem;
    }

    .theme-tab {
      font-size: 9.5px;
      padding: 0.24rem 0.48rem;
    }

    .preview-stage--compact .preview-theme-panel {
      min-height: clamp(220px, 31svh, 300px);
    }

    .preview-stage--compact .shiki-wrap {
      max-height: clamp(150px, 23svh, 220px);
    }

    .shiki-wrap :global(code) {
      font-size: 11px;
      line-height: 1.62;
    }
  }

  .shiki-wrap :global(pre) {
    background: transparent !important;
    margin: 0;
    padding: 0;
  }
  .shiki-wrap :global(code) {
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.82;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(html:lang(zh)) .shiki-wrap :global(code),
  :global(html:lang(ja)) .shiki-wrap :global(code) {
    font-family:
      "JetBrains Mono",
      "Cascadia Mono",
      "Cascadia Code",
      "Consolas",
      "Sarasa Mono SC",
      "Sarasa Mono J",
      "Noto Sans Mono CJK SC",
      "Noto Sans Mono CJK JP",
      "Microsoft YaHei UI",
      "Yu Gothic UI",
      monospace;
    line-height: 1.92;
  }

  @keyframes preview-enter {
    0% {
      opacity: 0;
      transform: translateY(8px) scale(0.996);
      filter: saturate(0.92);
    }

    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: saturate(1);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-code-preview]').forEach(root => {
    if (root.dataset.previewReady === 'true') return
    root.dataset.previewReady = 'true'

    const fileTabs = root.querySelectorAll<HTMLElement>('[data-file-tab]')
    const filePanels = root.querySelectorAll<HTMLElement>('[data-file-panel]')
    const themeTabs = root.querySelectorAll<HTMLElement>('[data-theme-tab]')
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const fileOrder = Array.from(fileTabs).map(tab => tab.dataset.fileTab).filter(Boolean) as string[]
    const themeOrder = Array.from(themeTabs).map(tab => tab.dataset.themeTab).filter(Boolean) as string[]

    let currentFile = fileOrder[0] ?? 'ts'
    let currentTheme = themeOrder[0] ?? 'dark'
    let lastInteractionAt = 0
    let fileTimer: number | undefined
    let themeTimer: number | undefined

    const INTERACTION_PAUSE_MS = 12000
    const FILE_INTERVAL_MS = 6800
    const THEME_INTERVAL_MS = 17000

    const markInteraction = () => {
      lastInteractionAt = Date.now()
    }

    const triggerEnter = (el: Element | null, animate = true) => {
      if (!el || !animate || prefersReducedMotion) return
      const target = el as HTMLElement
      target.classList.remove('is-entering')
      void target.offsetWidth
      target.classList.add('is-entering')
      window.setTimeout(() => target.classList.remove('is-entering'), 700)
    }

    const setTheme = (themeKey: string | null, animate = true) => {
      if (!themeKey) return
      currentTheme = themeKey

      themeTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.themeTab === themeKey)
      })

      filePanels.forEach(filePanel => {
        const scopedThemes = filePanel.querySelectorAll<HTMLElement>('[data-theme-panel]')
        scopedThemes.forEach(panel => {
          panel.classList.toggle('hidden', panel.dataset.themePanel !== themeKey)
        })
      })

      const activeFilePanel = root.querySelector<HTMLElement>(`[data-file-panel="${currentFile}"]`)
      const activeThemePanel = activeFilePanel?.querySelector<HTMLElement>(`[data-theme-panel="${currentTheme}"]`)
      triggerEnter(activeThemePanel ?? null, animate)
    }

    const setFile = (fileKey: string | null, animate = true) => {
      if (!fileKey) return
      currentFile = fileKey

      fileTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.fileTab === fileKey)
      })

      filePanels.forEach(panel => {
        panel.classList.toggle('hidden', panel.dataset.filePanel !== fileKey)
      })

      const activeFilePanel = root.querySelector<HTMLElement>(`[data-file-panel="${currentFile}"]`)
      triggerEnter(activeFilePanel ?? null, animate)

      const activeThemePanel = activeFilePanel?.querySelector<HTMLElement>(`[data-theme-panel="${currentTheme}"]`)
      triggerEnter(activeThemePanel ?? null, animate)
    }

    const nextFrom = (items: string[], current: string) => {
      if (!items.length) return current
      const idx = items.indexOf(current)
      return items[(idx + 1 + items.length) % items.length]
    }

    const setupAutoCarousel = () => {
      if (root.dataset.autoCarousel !== 'true' || prefersReducedMotion) return
      if (!window.matchMedia('(min-width: 861px)').matches) return
      if (fileOrder.length < 2 && themeOrder.length < 2) return

      fileTimer = window.setInterval(() => {
        if (Date.now() - lastInteractionAt < INTERACTION_PAUSE_MS) return
        const nextFile = nextFrom(fileOrder, currentFile)
        setFile(nextFile, true)
      }, FILE_INTERVAL_MS)

      themeTimer = window.setInterval(() => {
        if (Date.now() - lastInteractionAt < INTERACTION_PAUSE_MS) return
        const nextTheme = nextFrom(themeOrder, currentTheme)
        setTheme(nextTheme, true)
      }, THEME_INTERVAL_MS)
    }

    fileTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        setFile(tab.dataset.fileTab ?? null, true)
      })
    })

    themeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        setTheme(tab.dataset.themeTab ?? null, true)
      })
    })

    root.addEventListener('pointerenter', markInteraction, { passive: true })
    root.addEventListener('focusin', markInteraction, { passive: true })

    setTheme(currentTheme, false)
    setFile(currentFile, false)
    setupAutoCarousel()

    window.addEventListener('beforeunload', () => {
      if (fileTimer) window.clearInterval(fileTimer)
      if (themeTimer) window.clearInterval(themeTimer)
    })
  })
</script>
