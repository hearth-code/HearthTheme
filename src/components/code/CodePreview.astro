---
import { readFileSync } from 'node:fs'
import { t, type Lang } from '../../i18n/utils'
import { codeToHtml } from 'shiki'

interface Props {
  lang: Lang
  compact?: boolean
}

const { lang, compact = false } = Astro.props

type ThemeKey = 'dark' | 'soft' | 'light' | 'lightSoft'

type PreviewTheme = {
  name: string
  type: 'dark' | 'light'
  colors: Record<string, string>
  tokenColors: Array<{
    scope?: string | string[]
    settings?: { foreground?: string }
  }>
}

type PreviewThemeState = {
  label: string
  panelBg: string
  stripBg: string
  stripColor: string
  stripBorder: string
  toolbarBg: string
  toolbarBorder: string
  tabColor: string
  tabHoverColor: string
  tabActiveColor: string
  switchColor: string
  switchHoverColor: string
  switchActiveColor: string
  paper: boolean
}

function loadTheme(relativePath: string, name: string, type: 'dark' | 'light'): PreviewTheme {
  const raw = JSON.parse(readFileSync(new URL(relativePath, import.meta.url), 'utf8'))
  return {
    ...raw,
    name,
    type,
  } as PreviewTheme
}

function getTokenColor(theme: PreviewTheme, scopes: string[]): string | null {
  for (const entry of theme.tokenColors || []) {
    const entryScopes = Array.isArray(entry.scope) ? entry.scope : [entry.scope]
    if (!entryScopes.some((scope) => scopes.includes(String(scope || '')))) continue
    if (entry.settings?.foreground) return entry.settings.foreground
  }
  return null
}

function requireThemeColor(value: string | undefined, key: string): string {
  if (!value) {
    throw new Error(`CodePreview: missing required theme color "${key}"`)
  }
  return value
}

function getPanelPalette(theme: PreviewTheme) {
  const bg = requireThemeColor(theme.colors?.['editor.background'], 'editor.background')
  const fg = requireThemeColor(theme.colors?.['editor.foreground'], 'editor.foreground')
  const sidebar = theme.colors?.['sideBar.background'] || bg
  const comment = getTokenColor(theme, ['comment'])
    || fg
    || theme.colors?.['editorLineNumber.foreground']
    || sidebar
  const variable = getTokenColor(theme, ['variable', 'variable.other.readwrite'])
    || fg
    || comment
  return { bg, fg, sidebar, comment, variable }
}

function escapeJsonForScript(value: unknown): string {
  return JSON.stringify(value).replace(/</g, '\\u003c')
}

const HearthDark = loadTheme('../../../themes/hearth-dark.json', 'Hearth Dark', 'dark')
const HearthDarkSoft = loadTheme('../../../themes/hearth-dark-soft.json', 'Hearth Dark Soft', 'dark')
const HearthLight = loadTheme('../../../themes/hearth-light.json', 'Hearth Light', 'light')
const HearthLightSoft = loadTheme('../../../themes/hearth-light-soft.json', 'Hearth Light Soft', 'light')

const d = getPanelPalette(HearthDark)
const s = getPanelPalette(HearthDarkSoft)
const l = getPanelPalette(HearthLight)
const ls = getPanelPalette(HearthLightSoft)

const samples = {
  ts: `// async data fetching with full type safety
import { createContext, useContext } from 'react'

interface ApiResponse<T> {
  data: T
  status: number
  ok: boolean
}

async function request<T>(
  url: string,
  options?: RequestInit
): Promise<ApiResponse<T>> {
  const res = await fetch(url, options)
  const data = await res.json() as T
  return { data, status: res.status, ok: res.ok }
}

const BASE = 'https://api.hearthcode.dev'
const TIMEOUT = 5_000`,

  py: `# dataclass-based connection pool
from dataclasses import dataclass, field
from typing import Optional, ClassVar
import asyncio

@dataclass
class Connection:
    host: str
    port: int = 5432
    timeout: float = 30.0

class Pool:
    MAX: ClassVar[int] = 20

    def __init__(self, dsn: str):
        self.dsn = dsn
        self._pool: list[Connection] = []

    async def acquire(self) -> Optional[Connection]:
        if not self._pool:
            return None
        return self._pool.pop()`,

  go: `// HTTP server with graceful shutdown
package main

import (
  "context"
  "net/http"
  "time"
)

type Server struct {
  addr    string
  timeout time.Duration
  mux     *http.ServeMux
}

func New(addr string) *Server {
  return &Server{
    addr:    addr,
    timeout: 10 * time.Second,
    mux:     http.NewServeMux(),
  }
}`,

  rs: `// typed parser with Result and Option
use std::collections::HashMap;

#[derive(Debug, Clone)]
struct Config {
    host: String,
    port: u16,
}

fn load_config(env: &HashMap<String, String>) -> Result<Config, String> {
    let host = env.get("HOST").cloned().unwrap_or_else(|| "127.0.0.1".into());
    let port = env
        .get("PORT")
        .and_then(|v| v.parse::<u16>().ok())
        .unwrap_or(8080);
    Ok(Config { host, port })
}`,

  java: `// immutable service model with records
import java.time.Duration;
import java.util.List;

public final class HearthService {
  private final String endpoint;
  private final Duration timeout;

  public HearthService(String endpoint) {
    this.endpoint = endpoint;
    this.timeout = Duration.ofSeconds(5);
  }

  public record Result<T>(T data, int status) {}
}`,

  bash: `#!/usr/bin/env bash
set -euo pipefail

APP_NAME="hearth"
BUILD_DIR="./dist"

echo "[\${APP_NAME}] cleaning old build"
rm -rf "\${BUILD_DIR}"

echo "[\${APP_NAME}] building site"
npm run build
`,

  html: `<!-- Hearth UI component -->
<style>
  :root {
    --HearthCode: var(--hearth-ember);
    --bg: var(--hearth-bg);
  }
  .card {
    background: var(--bg);
    border: 1px solid var(--HearthCode);
    border-radius: 8px;
    padding: 1.5rem;
  }
</style>

<div class="card">
  <h2>HearthCode</h2>
  <p>Code by Hearthlight</p>
</div>`,
}

const langMap: Record<string, string> = {
  ts: 'typescript',
  py: 'python',
  go: 'go',
  rs: 'rust',
  java: 'java',
  bash: 'bash',
  html: 'html',
}

const rendered: Record<string, Record<ThemeKey, string>> = {}
for (const [key, code] of Object.entries(samples)) {
  const [dark, soft, light, lightSoft] = await Promise.all([
    codeToHtml(code, { lang: langMap[key], theme: HearthDark }),
    codeToHtml(code, { lang: langMap[key], theme: HearthDarkSoft }),
    codeToHtml(code, { lang: langMap[key], theme: HearthLight }),
    codeToHtml(code, { lang: langMap[key], theme: HearthLightSoft }),
  ])
  rendered[key] = { dark, soft, light, lightSoft }
}

const tabs = [
  { key: 'ts', label: 'index.ts' },
  { key: 'py', label: 'main.py' },
  { key: 'go', label: 'server.go' },
  { key: 'rs', label: 'main.rs' },
  { key: 'java', label: 'App.java' },
  { key: 'bash', label: 'build.sh' },
  { key: 'html', label: 'index.html' },
]

const previewThemeStateByKey: Record<ThemeKey, PreviewThemeState> = {
  dark: {
    label: 'Hearth Dark',
    panelBg: d.bg,
    stripBg: d.sidebar,
    stripColor: d.comment,
    stripBorder: 'var(--hearth-preview-strip-border-dark)',
    toolbarBg: d.sidebar,
    toolbarBorder: 'var(--hearth-preview-strip-border-dark)',
    tabColor: d.comment,
    tabHoverColor: d.variable,
    tabActiveColor: d.fg,
    switchColor: d.comment,
    switchHoverColor: d.variable,
    switchActiveColor: d.fg,
    paper: false,
  },
  soft: {
    label: 'Hearth Dark Soft',
    panelBg: s.bg,
    stripBg: s.sidebar,
    stripColor: s.comment,
    stripBorder: 'var(--hearth-preview-strip-border-dark)',
    toolbarBg: s.sidebar,
    toolbarBorder: 'var(--hearth-preview-strip-border-dark)',
    tabColor: s.comment,
    tabHoverColor: s.variable,
    tabActiveColor: s.fg,
    switchColor: s.comment,
    switchHoverColor: s.variable,
    switchActiveColor: s.fg,
    paper: false,
  },
  light: {
    label: 'Hearth Light',
    panelBg: l.bg,
    stripBg: l.sidebar,
    stripColor: l.comment,
    stripBorder: 'var(--hearth-preview-strip-border-light)',
    toolbarBg: l.sidebar,
    toolbarBorder: 'var(--hearth-preview-strip-border-light)',
    tabColor: l.comment,
    tabHoverColor: l.variable,
    tabActiveColor: l.variable,
    switchColor: l.comment,
    switchHoverColor: l.variable,
    switchActiveColor: l.variable,
    paper: true,
  },
  lightSoft: {
    label: 'Hearth Light Soft',
    panelBg: ls.bg,
    stripBg: ls.sidebar,
    stripColor: ls.comment,
    stripBorder: 'var(--hearth-preview-strip-border-light)',
    toolbarBg: ls.sidebar,
    toolbarBorder: 'var(--hearth-preview-strip-border-light)',
    tabColor: ls.comment,
    tabHoverColor: ls.variable,
    tabActiveColor: ls.variable,
    switchColor: ls.comment,
    switchHoverColor: ls.variable,
    switchActiveColor: ls.variable,
    paper: true,
  },
}

const previewRootStyle = [
  `--preview-toolbar-bg: ${previewThemeStateByKey.dark.toolbarBg}`,
  `--preview-toolbar-border: ${previewThemeStateByKey.dark.toolbarBorder}`,
  `--preview-tab-color: ${previewThemeStateByKey.dark.tabColor}`,
  `--preview-tab-hover-color: ${previewThemeStateByKey.dark.tabHoverColor}`,
  `--preview-tab-active-color: ${previewThemeStateByKey.dark.tabActiveColor}`,
  `--preview-switch-color: ${previewThemeStateByKey.dark.switchColor}`,
  `--preview-switch-hover-color: ${previewThemeStateByKey.dark.switchHoverColor}`,
  `--preview-switch-active-color: ${previewThemeStateByKey.dark.switchActiveColor}`,
  `--preview-panel-bg: ${previewThemeStateByKey.dark.panelBg}`,
  `--preview-strip-bg: ${previewThemeStateByKey.dark.stripBg}`,
  `--preview-strip-color: ${previewThemeStateByKey.dark.stripColor}`,
  `--preview-strip-border-color: ${previewThemeStateByKey.dark.stripBorder}`,
].join('; ')

const previewThemeJson = escapeJsonForScript(previewThemeStateByKey)
const renderedJson = escapeJsonForScript(rendered)
---

{
  compact ? (
    <div class="code-preview-root" data-code-preview data-auto-carousel="true" style={previewRootStyle}>
      <script type="application/json" data-preview-rendered set:html={renderedJson}></script>
      <script type="application/json" data-preview-themes set:html={previewThemeJson}></script>

      <div class="preview-stage preview-stage--compact overflow-hidden">
        <div class="preview-toolbar px-2.5 sm:px-3 py-2.5 sm:py-3">
          <div class="flex overflow-x-auto whitespace-nowrap gap-2" data-preview-tabs>
            {tabs.map(({ key, label }) => (
              <button
                type="button"
                data-file-tab={key}
                class={`preview-tab hearth-tab font-ui text-[12px] sm:text-[12.5px] px-3 sm:px-3.5 py-2 ${key === 'ts' ? 'is-active' : ''}`}
              >
                {label}
              </button>
            ))}
          </div>
          <div class="theme-switch mt-2 sm:mt-2.5 inline-flex gap-1 rounded-full border p-1">
            <button type="button" data-theme-tab="dark" class="theme-tab is-active">Dark</button>
            <button type="button" data-theme-tab="soft" class="theme-tab">Dark Soft</button>
            <button type="button" data-theme-tab="light" class="theme-tab">Light</button>
            <button type="button" data-theme-tab="lightSoft" class="theme-tab">Light Soft</button>
          </div>
        </div>

        <div class="preview-display preview-theme-panel" data-preview-display>
          <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5" data-preview-theme-label>
            Hearth Dark
          </div>
          <div
            class="preview-content overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
            data-preview-content
            set:html={rendered.ts.dark}
          />
        </div>
      </div>
    </div>
  ) : (
    <section class="hearth-section pt-6 sm:pt-8 pb-12 sm:pb-16" data-reveal>
      <div class="hearth-shell">
        <div class="hearth-intro">
          <p class="hearth-kicker mb-5 flex items-center gap-3">
            {t(lang, 'preview.label')}
            <span class="hearth-line"></span>
          </p>
        </div>

        <div class="code-preview-root preview-stage overflow-hidden" data-code-preview style={previewRootStyle}>
          <script type="application/json" data-preview-rendered set:html={renderedJson}></script>
          <script type="application/json" data-preview-themes set:html={previewThemeJson}></script>

          <div class="preview-toolbar px-2.5 sm:px-3 py-2.5 sm:py-3">
            <div class="flex overflow-x-auto whitespace-nowrap gap-2" data-preview-tabs>
              {tabs.map(({ key, label }) => (
                <button
                  type="button"
                  data-file-tab={key}
                  class={`preview-tab hearth-tab font-ui text-[12px] sm:text-[12.5px] px-3 sm:px-3.5 py-2 ${key === 'ts' ? 'is-active' : ''}`}
                >
                  {label}
                </button>
              ))}
            </div>
            <div class="theme-switch mt-2 sm:mt-2.5 inline-flex gap-1 rounded-full border p-1">
              <button type="button" data-theme-tab="dark" class="theme-tab is-active">Dark</button>
              <button type="button" data-theme-tab="soft" class="theme-tab">Dark Soft</button>
              <button type="button" data-theme-tab="light" class="theme-tab">Light</button>
              <button type="button" data-theme-tab="lightSoft" class="theme-tab">Light Soft</button>
            </div>
          </div>

          <div class="preview-display preview-theme-panel" data-preview-display>
            <div class="theme-strip font-ui text-[10px] tracking-[0.09em] uppercase px-4 py-2.5" data-preview-theme-label>
              Hearth Dark
            </div>
            <div
              class="preview-content overflow-hidden text-[13px] leading-relaxed p-4 sm:p-5 shiki-wrap"
              data-preview-content
              set:html={rendered.ts.dark}
            />
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .code-preview-root {
    border: none;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(180deg, var(--hearth-preview-shell-grad-start), var(--hearth-preview-shell-grad-end));
    box-shadow:
      0 48px 90px var(--hearth-preview-shell-shadow-deep),
      0 14px 28px var(--hearth-preview-shell-shadow-mid),
      inset 0 1px 0 var(--hearth-preview-shell-edge);
  }

  .preview-stage {
    background: linear-gradient(180deg, var(--hearth-preview-stage-grad-start), var(--hearth-preview-stage-grad-end));
    box-shadow: 0 20px 36px var(--hearth-shadow-016);
  }

  .preview-stage--compact {
    box-shadow: none;
  }

  .preview-toolbar {
    background: var(--preview-toolbar-bg);
    border-bottom: 1px solid var(--preview-toolbar-border);
    transition:
      background-color 260ms var(--hearth-ease),
      border-color 260ms var(--hearth-ease);
  }

  .preview-tab {
    position: relative;
    color: var(--preview-tab-color);
    background: transparent;
    border: none;
    border-radius: 0;
    font-weight: 560;
    line-height: 1;
  }

  .preview-tab::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.08rem;
    height: 1.5px;
    background: currentColor;
    opacity: 0;
    transform: scaleX(0.45);
    transform-origin: center;
    transition:
      opacity 220ms var(--hearth-ease),
      transform 220ms var(--hearth-ease);
  }

  .preview-tab:hover {
    color: var(--preview-tab-hover-color);
  }

  .preview-tab:hover::after {
    opacity: 0.45;
    transform: scaleX(1);
  }

  .preview-tab.is-active {
    color: var(--preview-tab-active-color);
    text-shadow: 0 0 10px var(--hearth-preview-tab-active-shadow);
  }

  .theme-switch {
    border-color: var(--hearth-preview-switch-border);
  }

  .preview-tab.is-active::after {
    opacity: 0.92;
    transform: scaleX(1);
  }

  .theme-tab {
    border: none;
    border-radius: 9999px;
    padding: 0.3rem 0.72rem;
    background: transparent;
    color: var(--preview-switch-color);
    font-family: var(--font-ui);
    font-size: 11px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: color 220ms var(--hearth-ease), background-color 220ms var(--hearth-ease);
  }

  .theme-tab:hover {
    color: var(--preview-switch-hover-color);
  }

  .theme-tab.is-active {
    color: var(--preview-switch-active-color);
    background: var(--hearth-preview-switch-active-bg);
    box-shadow: inset 0 0 0 1px var(--hearth-preview-switch-active-ring);
  }

  .preview-display {
    position: relative;
    min-height: 380px;
    background: var(--preview-panel-bg);
    transition: background-color 260ms var(--hearth-ease);
  }

  .theme-strip {
    background: var(--preview-strip-bg);
    color: var(--preview-strip-color);
    border-bottom: 1px solid var(--preview-strip-border-color);
    transition:
      background-color 260ms var(--hearth-ease),
      color 220ms var(--hearth-ease),
      border-color 260ms var(--hearth-ease);
  }

  .preview-content {
    position: relative;
    will-change: opacity, filter;
  }

  .preview-content.is-refreshing {
    animation: preview-content-refresh 420ms var(--hearth-ease);
  }

  .preview-content::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--preview-strip-color) 12%, transparent) 0%,
      transparent 34%
    );
  }

  .preview-content.is-refreshing::after {
    animation: preview-content-sheen 420ms var(--hearth-ease);
  }

  .preview-stage--compact .preview-display {
    min-height: clamp(390px, 53svh, 540px);
  }

  .preview-stage--compact .shiki-wrap {
    max-height: clamp(340px, 48svh, 480px);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 86%, transparent 100%);
    mask-image: linear-gradient(180deg, black 0%, black 86%, transparent 100%);
    scrollbar-width: none;
  }

  .preview-stage--compact .shiki-wrap::-webkit-scrollbar {
    width: 0;
    height: 0;
    background: transparent;
  }

  @media (max-width: 860px) {
    .code-preview-root {
      width: min(92vw, 520px);
      margin-inline: auto;
      border-radius: 16px;
      box-shadow:
        0 26px 48px var(--hearth-preview-mobile-shadow-deep),
        0 8px 18px var(--hearth-shadow-024),
        inset 0 1px 0 var(--hearth-paper-grid-soft);
    }

    .preview-toolbar {
      padding-block: 0.48rem;
      padding-inline: 0.54rem;
    }

    .preview-tab {
      font-size: 11px;
    }

    .theme-tab {
      font-size: 10px;
      padding: 0.26rem 0.56rem;
    }

    .preview-stage--compact .preview-display {
      min-height: clamp(250px, 34svh, 340px);
    }

    .preview-stage--compact .shiki-wrap {
      max-height: clamp(180px, 27svh, 260px);
      -webkit-mask-image: linear-gradient(180deg, black 0%, black 84%, transparent 100%);
      mask-image: linear-gradient(180deg, black 0%, black 84%, transparent 100%);
    }

    .shiki-wrap :global(code) {
      font-size: 12px;
      line-height: 1.72;
    }
  }

  @media (max-width: 480px) {
    .code-preview-root {
      width: min(94vw, 430px);
      border-radius: 14px;
    }

    .preview-toolbar {
      padding-inline: 0.46rem;
    }

    .preview-tab {
      font-size: 10px;
      padding-inline: 0.52rem;
      padding-block: 0.42rem;
    }

    .theme-tab {
      font-size: 9.5px;
      padding: 0.24rem 0.48rem;
    }

    .preview-stage--compact .preview-display {
      min-height: clamp(220px, 31svh, 300px);
    }

    .preview-stage--compact .shiki-wrap {
      max-height: clamp(150px, 23svh, 220px);
    }

    .shiki-wrap :global(code) {
      font-size: 11px;
      line-height: 1.62;
    }
  }

  .shiki-wrap :global(pre) {
    background: transparent !important;
    margin: 0;
    padding: 0;
  }

  .shiki-wrap :global(code) {
    font-family: var(--font-code);
    font-size: 13px;
    line-height: 1.82;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  :global(html:lang(zh)) .shiki-wrap :global(code),
  :global(html:lang(ja)) .shiki-wrap :global(code) {
    font-family:
      "JetBrains Mono",
      "Cascadia Mono",
      "Cascadia Code",
      "Consolas",
      "Sarasa Mono SC",
      "Sarasa Mono J",
      "Noto Sans Mono CJK SC",
      "Noto Sans Mono CJK JP",
      "Microsoft YaHei UI",
      "Yu Gothic UI",
      monospace;
    line-height: 1.92;
  }

  @keyframes preview-content-refresh {
    0% {
      opacity: 0.22;
      filter: blur(1.2px) saturate(0.9);
    }

    55% {
      opacity: 0.8;
      filter: blur(0.2px) saturate(0.97);
    }

    100% {
      opacity: 1;
      filter: saturate(1);
    }
  }

  @keyframes preview-content-sheen {
    0% {
      opacity: 0;
    }

    18% {
      opacity: 0.75;
    }

    100% {
      opacity: 0;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-code-preview]').forEach(root => {
    if (root.dataset.previewReady === 'true') return
    root.dataset.previewReady = 'true'

    const fileTabs = root.querySelectorAll<HTMLElement>('[data-file-tab]')
    const themeTabs = root.querySelectorAll<HTMLElement>('[data-theme-tab]')
    const previewDisplay = root.querySelector<HTMLElement>('[data-preview-display]')
    const previewContent = root.querySelector<HTMLElement>('[data-preview-content]')
    const themeLabel = root.querySelector<HTMLElement>('[data-preview-theme-label]')
    const renderedScript = root.querySelector<HTMLScriptElement>('[data-preview-rendered]')
    const themeScript = root.querySelector<HTMLScriptElement>('[data-preview-themes]')

    const renderedMap = (() => {
      try {
        return JSON.parse(renderedScript?.textContent || '{}') as Record<string, Record<string, string>>
      } catch {
        return {}
      }
    })()

    const themeStateMap = (() => {
      try {
        return JSON.parse(themeScript?.textContent || '{}') as Record<string, Record<string, string | boolean>>
      } catch {
        return {}
      }
    })()

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    const fileOrder = Array.from(fileTabs).map(tab => tab.dataset.fileTab).filter(Boolean) as string[]
    const themeOrder = Array.from(themeTabs).map(tab => tab.dataset.themeTab).filter(Boolean) as string[]

    let currentFile = fileOrder[0] ?? 'ts'
    let currentTheme = themeOrder[0] ?? 'dark'
    let currentRenderKey = `${currentFile}:${currentTheme}`
    let lastInteractionAt = 0
    let fileTimer: number | undefined
    let themeTimer: number | undefined

    const INTERACTION_PAUSE_MS = 12000
    const FILE_INTERVAL_MS = 6800
    const THEME_INTERVAL_MS = 17000

    const markInteraction = () => {
      lastInteractionAt = Date.now()
    }

    const triggerRefresh = (el: HTMLElement | null, animate = true) => {
      if (!el || !animate || prefersReducedMotion) return
      el.classList.remove('is-refreshing')
      window.requestAnimationFrame(() => {
        el.classList.add('is-refreshing')
        window.setTimeout(() => el.classList.remove('is-refreshing'), 460)
      })
    }

    const renderActive = (animate = true) => {
      const nextRenderKey = `${currentFile}:${currentTheme}`
      const nextHtml = renderedMap?.[currentFile]?.[currentTheme]
      if (previewContent && nextHtml && currentRenderKey !== nextRenderKey) {
        previewContent.innerHTML = nextHtml
      }
      currentRenderKey = nextRenderKey
      triggerRefresh(previewContent, animate)
    }

    const applyThemeUi = (themeKey: string) => {
      const ui = themeStateMap?.[themeKey]
      if (!ui) return
      if (typeof ui.toolbarBg === 'string') root.style.setProperty('--preview-toolbar-bg', ui.toolbarBg)
      if (typeof ui.toolbarBorder === 'string') root.style.setProperty('--preview-toolbar-border', ui.toolbarBorder)
      if (typeof ui.tabColor === 'string') root.style.setProperty('--preview-tab-color', ui.tabColor)
      if (typeof ui.tabHoverColor === 'string') root.style.setProperty('--preview-tab-hover-color', ui.tabHoverColor)
      if (typeof ui.tabActiveColor === 'string') root.style.setProperty('--preview-tab-active-color', ui.tabActiveColor)
      if (typeof ui.switchColor === 'string') root.style.setProperty('--preview-switch-color', ui.switchColor)
      if (typeof ui.switchHoverColor === 'string') root.style.setProperty('--preview-switch-hover-color', ui.switchHoverColor)
      if (typeof ui.switchActiveColor === 'string') root.style.setProperty('--preview-switch-active-color', ui.switchActiveColor)
      if (typeof ui.panelBg === 'string') root.style.setProperty('--preview-panel-bg', ui.panelBg)
      if (typeof ui.stripBg === 'string') root.style.setProperty('--preview-strip-bg', ui.stripBg)
      if (typeof ui.stripColor === 'string') root.style.setProperty('--preview-strip-color', ui.stripColor)
      if (typeof ui.stripBorder === 'string') root.style.setProperty('--preview-strip-border-color', ui.stripBorder)

      if (themeLabel && typeof ui.label === 'string') {
        themeLabel.textContent = ui.label
      }

      if (previewDisplay) {
        previewDisplay.classList.toggle('hearth-paper', Boolean(ui.paper))
      }
    }

    const setTheme = (themeKey: string | null, animate = true) => {
      if (!themeKey) return
      currentTheme = themeKey
      applyThemeUi(themeKey)

      themeTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.themeTab === themeKey)
      })

      renderActive(animate)
    }

    const setFile = (fileKey: string | null, animate = true) => {
      if (!fileKey) return
      currentFile = fileKey

      fileTabs.forEach(tab => {
        tab.classList.toggle('is-active', tab.dataset.fileTab === fileKey)
      })

      renderActive(animate)
    }

    const nextFrom = (items: string[], current: string) => {
      if (!items.length) return current
      const idx = items.indexOf(current)
      return items[(idx + 1 + items.length) % items.length]
    }

    const setupAutoCarousel = () => {
      if (root.dataset.autoCarousel !== 'true' || prefersReducedMotion) return
      if (!window.matchMedia('(min-width: 861px)').matches) return
      if (fileOrder.length < 2 && themeOrder.length < 2) return

      fileTimer = window.setInterval(() => {
        if (Date.now() - lastInteractionAt < INTERACTION_PAUSE_MS) return
        const nextFile = nextFrom(fileOrder, currentFile)
        setFile(nextFile, true)
      }, FILE_INTERVAL_MS)

      themeTimer = window.setInterval(() => {
        if (Date.now() - lastInteractionAt < INTERACTION_PAUSE_MS) return
        const nextTheme = nextFrom(themeOrder, currentTheme)
        setTheme(nextTheme, true)
      }, THEME_INTERVAL_MS)
    }

    fileTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        setFile(tab.dataset.fileTab ?? null, true)
      })
    })

    themeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        markInteraction()
        setTheme(tab.dataset.themeTab ?? null, true)
      })
    })

    root.addEventListener('pointerenter', markInteraction, { passive: true })
    root.addEventListener('focusin', markInteraction, { passive: true })

    applyThemeUi(currentTheme)
    setFile(currentFile, false)
    setupAutoCarousel()

    window.addEventListener('beforeunload', () => {
      if (fileTimer) window.clearInterval(fileTimer)
      if (themeTimer) window.clearInterval(themeTimer)
    })
  })
</script>
