---
import { t, type Lang } from "../../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const metrics = [
  { valueKey: "proof.metric.1.value", labelKey: "proof.metric.1.label" },
  { valueKey: "proof.metric.2.value", labelKey: "proof.metric.2.label" },
  { valueKey: "proof.metric.3.value", labelKey: "proof.metric.3.label" },
];

const heroImage = "/previews/preview-contrast-v2.png";

const guide = [
  { titleKey: "proof.guide.dark.title", bodyKey: "proof.guide.dark.body" },
  { titleKey: "proof.guide.darkSoft.title", bodyKey: "proof.guide.darkSoft.body" },
  { titleKey: "proof.guide.light.title", bodyKey: "proof.guide.light.body" },
  { titleKey: "proof.guide.lightSoft.title", bodyKey: "proof.guide.lightSoft.body" },
];
---

<section id="design-preview" class="hearth-section hearth-section-y" data-reveal>
  <div class="hearth-shell">
    <div class="hearth-intro">
      <p class="hearth-kicker mb-4 flex items-center gap-3">
        {t(lang, "proof.label")}
        <span class="hearth-line"></span>
      </p>
      <h2 class="hearth-heading text-[1.9rem] sm:text-[2.25rem] leading-[1.18] tracking-[-0.015em] font-semibold mb-4">
        {t(lang, "proof.title")}
      </h2>
      <p class="hearth-copy hearth-copy-soft max-w-[920px] mb-8">
        {t(lang, "proof.subtitle")}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
      {
        metrics.map(({ valueKey, labelKey }, index) => (
          <article
            data-reveal
            style={`--reveal-delay: ${90 + index * 70}ms;`}
            class="hearth-proof-metric-card rounded-xl px-4 py-4"
          >
            <p class="hearth-proof-metric-title font-ui text-[1.1rem] font-semibold">{t(lang, valueKey)}</p>
            <p class="hearth-meta hearth-meta-muted mt-1">{t(lang, labelKey)}</p>
          </article>
        ))
      }
    </div>

    <article class="hearth-proof-hero-card rounded-[26px] overflow-hidden mb-8" data-reveal style="--reveal-delay: 180ms;">
      <img src={heroImage} alt={t(lang, "proof.title")} class="w-full h-auto block" loading="lazy" />
    </article>

    <div class="grid gap-4">
      <p class="hearth-copy hearth-copy-soft max-w-[920px] mb-0">
        {t(lang, "proof.compare.caption")}
      </p>

      <div>
        <h3 class="hearth-proof-variant-title font-ui text-[0.98rem] font-semibold mb-3">
          {t(lang, "proof.guide.title")}
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3">
          {
            guide.map(({ titleKey, bodyKey }, index) => (
              <article
                data-reveal
                style={`--reveal-delay: ${220 + index * 45}ms;`}
                class="hearth-proof-variant-card rounded-xl px-4 py-4 min-w-0"
              >
                <h4 class="hearth-proof-variant-title font-ui text-[0.92rem] font-semibold mb-2">{t(lang, titleKey)}</h4>
                <p class="hearth-proof-variant-body hearth-copy text-[0.93rem] leading-[1.62]">{t(lang, bodyKey)}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
