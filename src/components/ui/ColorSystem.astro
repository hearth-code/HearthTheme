---
import { t, type Lang } from "../../i18n/utils";
import { tokens } from "../../data/tokens";

interface Props {
    lang: Lang;
}

type VariantId = keyof typeof tokens;
type TokenId = keyof (typeof tokens)["dark"];

const { lang } = Astro.props;
const docsUrl = lang === "en" ? "/docs" : `/${lang}/docs`;
const reportUrl = "https://github.com/hearth-code/HearthTheme/blob/main/docs/color-language-report.md";
const sourceUrl = "https://github.com/hearth-code/HearthTheme/tree/main/color-system";

function hexToRgb(hex: string) {
    const raw = hex.slice(1);
    return [
        Number.parseInt(raw.slice(0, 2), 16),
        Number.parseInt(raw.slice(2, 4), 16),
        Number.parseInt(raw.slice(4, 6), 16),
    ];
}

function toLinear(channel: number) {
    const c = channel / 255;
    return c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
}

function contrastRatio(a: string, b: string) {
    const [ar, ag, ab] = hexToRgb(a).map(toLinear);
    const [br, bg, bb] = hexToRgb(b).map(toLinear);
    const la = 0.2126 * ar + 0.7152 * ag + 0.0722 * ab;
    const lb = 0.2126 * br + 0.7152 * bg + 0.0722 * bb;
    const hi = Math.max(la, lb);
    const lo = Math.min(la, lb);
    return (hi + 0.05) / (lo + 0.05);
}

function withAlpha(hex: string, alpha: number) {
    const normalized = Math.min(Math.max(alpha, 0), 1);
    const alphaHex = Math.round(normalized * 255)
        .toString(16)
        .padStart(2, "0");
    return `${hex}${alphaHex}`;
}

function getToken(variant: VariantId, token: TokenId) {
    return tokens[variant][token];
}

function getContrastMetric(a: string, b: string | null) {
    if (!b) {
        return {
            contrast: "—",
            level: "",
        };
    }

    const ratio = contrastRatio(a, b);
    return {
        contrast: `${ratio.toFixed(1)}:1`,
        level: ratio >= 7 ? "aaa" : ratio >= 4.5 ? "aa" : "dec",
    };
}

const levelClass: Record<string, string> = {
    aaa: "hearth-badge-aaa",
    aa: "hearth-badge-aa",
    dec: "hearth-badge-dec",
    "": "hearth-badge-dec",
};

const copy = {
    en: {
        darkEyebrow: "Dark family",
        darkTitle: "Warm night canvas",
        darkBody: "Charcoal surfaces stay calm and focused while the syntax accents still feel alive.",
        lightEyebrow: "Light family",
        lightTitle: "Paper tones for long reading",
        lightBody: "Parchment backgrounds keep the bright side gentle, readable, and still clearly structured.",
        surfaceLabel: "Canvas pair",
        roleLabel: "Signature syntax anchors",
    },
    zh: {
        darkEyebrow: "深色组",
        darkTitle: "温暖的夜色画布",
        darkBody: "炭黑底色保持安静与专注，语义色点到为止，但仍然有存在感。",
        lightEyebrow: "浅色组",
        lightTitle: "适合长读的纸面色调",
        lightBody: "纸张感背景让亮面更柔和，阅读更轻松，层级也依然清楚。",
        surfaceLabel: "底色与阅读面",
        roleLabel: "代表性色",
    },
    ja: {
        darkEyebrow: "ダーク系",
        darkTitle: "温かい夜のキャンバス",
        darkBody: "木炭のような背景で集中を保ちつつ、構文色は静かに効かせています。",
        lightEyebrow: "ライト系",
        lightTitle: "長時間読める紙のトーン",
        lightBody: "紙のような背景でまぶしさを抑え、明るい面でも階層が崩れません。",
        surfaceLabel: "土台と読む面",
        roleLabel: "代表的な構文色",
    },
} satisfies Record<
    Lang,
    {
        darkEyebrow: string;
        darkTitle: string;
        darkBody: string;
        lightEyebrow: string;
        lightTitle: string;
        lightBody: string;
        surfaceLabel: string;
        roleLabel: string;
    }
>;

const localeCopy = copy[lang];

function buildSurfaceCard(options: {
    name: string;
    variant: VariantId;
    roleKey: string;
}) {
    return {
        name: options.name,
        hex: getToken(options.variant, "bg"),
        description: t(lang, options.roleKey),
        bg: getToken(options.variant, "bg"),
        fg: getToken(options.variant, "fg"),
        muted: getToken(options.variant, "comment"),
        border: withAlpha(getToken(options.variant, "border"), 0.92),
        highlight: withAlpha(getToken(options.variant, "fg"), options.variant === "light" || options.variant === "lightSoft" ? 0.12 : 0.08),
        shadow: withAlpha(getToken(options.variant, "status"), options.variant === "light" || options.variant === "lightSoft" ? 0.16 : 0.14),
    };
}

function buildRoleCard(options: {
    name: string;
    variant: VariantId;
    token: TokenId;
    bgVariant: VariantId;
    bgToken?: TokenId;
    roleKey: string;
}) {
    const swatch = getToken(options.variant, options.token);
    const bg = getToken(options.bgVariant, options.bgToken ?? "bg");
    const metric = getContrastMetric(swatch, bg);

    return {
        name: options.name,
        hex: swatch,
        description: t(lang, options.roleKey),
        accent: swatch,
        contrast: metric.contrast,
        level: metric.level,
    };
}

const darkSurfaceCards = [
    buildSurfaceCard({
        name: "bg · dark",
        variant: "dark",
        roleKey: "colors.role.bg.dark",
    }),
    buildSurfaceCard({
        name: "bg · dark-soft",
        variant: "darkSoft",
        roleKey: "colors.role.bg.darkSoft",
    }),
];

const lightSurfaceCards = [
    buildSurfaceCard({
        name: "bg · light",
        variant: "light",
        roleKey: "colors.role.bg.light",
    }),
    buildSurfaceCard({
        name: "bg · light-soft",
        variant: "lightSoft",
        roleKey: "colors.role.bg.lightSoft",
    }),
];

const darkRoleCards = [
    buildRoleCard({
        name: "keyword",
        variant: "dark",
        token: "keyword",
        bgVariant: "dark",
        roleKey: "colors.role.keyword",
    }),
    buildRoleCard({
        name: "function",
        variant: "dark",
        token: "fn",
        bgVariant: "dark",
        roleKey: "colors.role.function",
    }),
    buildRoleCard({
        name: "string",
        variant: "dark",
        token: "string",
        bgVariant: "dark",
        roleKey: "colors.role.string",
    }),
    buildRoleCard({
        name: "type",
        variant: "dark",
        token: "type",
        bgVariant: "dark",
        roleKey: "colors.role.type",
    }),
    buildRoleCard({
        name: "number",
        variant: "dark",
        token: "number",
        bgVariant: "dark",
        roleKey: "colors.role.number",
    }),
    buildRoleCard({
        name: "comment",
        variant: "dark",
        token: "comment",
        bgVariant: "dark",
        roleKey: "colors.role.comment",
    }),
];

const lightRoleCards = [
    buildRoleCard({
        name: "keyword",
        variant: "light",
        token: "keyword",
        bgVariant: "light",
        roleKey: "colors.role.keyword",
    }),
    buildRoleCard({
        name: "function",
        variant: "light",
        token: "fn",
        bgVariant: "light",
        roleKey: "colors.role.function",
    }),
    buildRoleCard({
        name: "string",
        variant: "light",
        token: "string",
        bgVariant: "light",
        roleKey: "colors.role.string",
    }),
    buildRoleCard({
        name: "type",
        variant: "light",
        token: "type",
        bgVariant: "light",
        roleKey: "colors.role.type",
    }),
    buildRoleCard({
        name: "number",
        variant: "light",
        token: "number",
        bgVariant: "light",
        roleKey: "colors.role.number",
    }),
    buildRoleCard({
        name: "comment",
        variant: "light",
        token: "comment",
        bgVariant: "light",
        roleKey: "colors.role.comment",
    }),
];

const families = [
    {
        id: "dark",
        eyebrow: localeCopy.darkEyebrow,
        title: localeCopy.darkTitle,
        body: localeCopy.darkBody,
        shellStart: withAlpha(getToken("dark", "sidebar"), 0.96),
        shellEnd: withAlpha(getToken("darkSoft", "bg"), 0.95),
        shellBorder: withAlpha(getToken("dark", "border"), 0.88),
        shadow: withAlpha(getToken("dark", "status"), 0.16),
        accent: withAlpha(getToken("dark", "status"), 0.88),
        headingColor: getToken("dark", "fg"),
        bodyColor: getToken("dark", "variable"),
        labelColor: getToken("dark", "comment"),
        shellHighlight: withAlpha(getToken("dark", "fg"), 0.08),
        roleHighlight: withAlpha(getToken("dark", "fg"), 0.06),
        roleBg: withAlpha(getToken("dark", "lineBg"), 0.84),
        roleBorder: withAlpha(getToken("dark", "border"), 0.78),
        surfaceCards: darkSurfaceCards,
        roleCards: darkRoleCards,
    },
    {
        id: "light",
        eyebrow: localeCopy.lightEyebrow,
        title: localeCopy.lightTitle,
        body: localeCopy.lightBody,
        shellStart: withAlpha(getToken("light", "bg"), 0.98),
        shellEnd: withAlpha(getToken("lightSoft", "lineBg"), 0.96),
        shellBorder: withAlpha(getToken("light", "border"), 0.92),
        shadow: withAlpha(getToken("light", "status"), 0.14),
        accent: withAlpha(getToken("light", "status"), 0.84),
        headingColor: getToken("light", "fg"),
        bodyColor: getToken("light", "variable"),
        labelColor: getToken("light", "comment"),
        shellHighlight: withAlpha(getToken("light", "fg"), 0.14),
        roleHighlight: withAlpha(getToken("light", "fg"), 0.1),
        roleBg: withAlpha(getToken("light", "lineBg"), 0.92),
        roleBorder: withAlpha(getToken("light", "border"), 0.86),
        surfaceCards: lightSurfaceCards,
        roleCards: lightRoleCards,
    },
];
---

<section class="hearth-section hearth-section-y hearth-color-section" data-reveal>
    <div class="hearth-shell">
        <div class="hearth-intro hearth-color-intro">
            <p class="hearth-kicker mb-5 flex items-center gap-3">
                {t(lang, "colors.label")}
                <span class="hearth-line"></span>
            </p>
        </div>

        <div class="hearth-color-board">
            {
                families.map((family) => (
                    <article
                        class={`hearth-color-family hearth-color-family--${family.id}`}
                        style={`
                            --family-shell-start: ${family.shellStart};
                            --family-shell-end: ${family.shellEnd};
                            --family-shell-border: ${family.shellBorder};
                            --family-shadow: ${family.shadow};
                            --family-accent: ${family.accent};
                            --family-heading: ${family.headingColor};
                            --family-body: ${family.bodyColor};
                            --family-label: ${family.labelColor};
                            --family-shell-highlight: ${family.shellHighlight};
                            --family-role-highlight: ${family.roleHighlight};
                            --family-role-bg: ${family.roleBg};
                            --family-role-border: ${family.roleBorder};
                        `}
                    >
                        <div class="hearth-color-family__header">
                            <div class="hearth-color-family__mast">
                                <p class="hearth-color-family__eyebrow">{family.eyebrow}</p>
                                <span class="hearth-color-family__rule" aria-hidden="true"></span>
                            </div>
                            <h3 class="hearth-color-family__title">{family.title}</h3>
                            <p class="hearth-color-family__body">{family.body}</p>
                        </div>

                        <div class="hearth-color-family__layout">
                            <section class="hearth-color-cluster hearth-color-cluster--surface">
                                <div class="hearth-color-cluster__header">
                                    <p class="hearth-color-section-label">{localeCopy.surfaceLabel}</p>
                                    <span class="hearth-color-cluster__rule" aria-hidden="true"></span>
                                </div>
                                <div class="hearth-color-surface-grid">
                                    {
                                        family.surfaceCards.map((card) => (
                                            <article
                                                class="hearth-color-surface-card"
                                                style={`
                                                    --surface-bg: ${card.bg};
                                                    --surface-fg: ${card.fg};
                                                    --surface-muted: ${card.muted};
                                                    --surface-border: ${card.border};
                                                    --surface-highlight: ${card.highlight};
                                                    --surface-shadow: ${card.shadow};
                                                `}
                                            >
                                                <div class="hearth-color-surface-card__swatch" aria-hidden="true">
                                                    <span class="hearth-color-surface-card__swatch-main"></span>
                                                    <span class="hearth-color-surface-card__swatch-muted"></span>
                                                </div>
                                                <div class="hearth-color-surface-card__meta">
                                                    <span class="hearth-color-surface-card__name">{card.name}</span>
                                                    <span class="hearth-color-surface-card__hex">{card.hex}</span>
                                                </div>
                                                <p class="hearth-color-surface-card__body">{card.description}</p>
                                            </article>
                                        ))
                                    }
                                </div>
                            </section>

                            <section class="hearth-color-cluster hearth-color-cluster--roles">
                                <div class="hearth-color-cluster__header">
                                    <p class="hearth-color-section-label">{localeCopy.roleLabel}</p>
                                    <span class="hearth-color-cluster__rule" aria-hidden="true"></span>
                                </div>
                                <div class="hearth-color-role-grid">
                                    {
                                        family.roleCards.map((card) => (
                                            <article
                                                class="hearth-color-role-card"
                                                style={`
                                                    --role-accent: ${card.accent};
                                                    --role-highlight: ${family.roleHighlight};
                                                `}
                                            >
                                                <div class="hearth-color-role-card__swatch" aria-hidden="true"></div>
                                                <div class="hearth-color-role-card__meta">
                                                    <span class="hearth-color-role-card__name">{card.name}</span>
                                                    <span class="hearth-color-role-card__hex">{card.hex}</span>
                                                </div>
                                                <p class="hearth-color-role-card__body">{card.description}</p>
                                                <div class="hearth-color-role-card__foot">
                                                    <span
                                                        class={`font-mono text-[10px] px-2.5 py-1 rounded-[999px] border flex-shrink-0 ${levelClass[card.level]}`}
                                                    >
                                                        {card.contrast}
                                                        {card.level === "aaa"
                                                            ? " AAA"
                                                            : card.level === "aa"
                                                              ? " AA"
                                                              : card.level === "dec"
                                                                ? " dec"
                                                                : ""}
                                                    </span>
                                                </div>
                                            </article>
                                        ))
                                    }
                                </div>
                            </section>
                        </div>
                    </article>
                ))
            }

            <article class="hearth-proof-metric-card hearth-color-proof rounded-[24px] px-5 sm:px-6 py-5 sm:py-6">
                <h3 class="hearth-proof-variant-title font-ui text-[1rem] font-semibold mb-2">
                    {t(lang, "colors.proof.title")}
                </h3>
                <p class="hearth-copy hearth-meta-muted text-[0.95rem] leading-[1.68] mb-4">
                    {t(lang, "colors.proof.body")}
                </p>
                <div class="flex flex-wrap gap-2.5 text-[0.8rem] font-ui tracking-[0.01em]">
                    <a
                        href={docsUrl}
                        class="hearth-btn-secondary inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 font-semibold"
                    >
                        <span>{t(lang, "colors.proof.cta.docs")}</span>
                        <span aria-hidden="true">→</span>
                    </a>
                    <a
                        href={reportUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hearth-btn-tertiary inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 font-semibold"
                    >
                        <span>{t(lang, "colors.proof.cta.report")}</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                    <a
                        href={sourceUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="hearth-btn-tertiary inline-flex items-center gap-1.5 rounded-full border px-3.5 py-1.5 font-semibold"
                    >
                        <span>{t(lang, "colors.proof.cta.source")}</span>
                        <span aria-hidden="true">↗</span>
                    </a>
                </div>
            </article>
        </div>
    </div>
</section>

<style>
    .hearth-color-section {
        position: relative;
    }

    .hearth-color-intro {
        margin-bottom: clamp(1.55rem, 3.4vw, 2.35rem);
    }

    .hearth-color-board {
        width: 100%;
        display: grid;
        gap: 1.25rem;
    }

    .hearth-color-family {
        position: relative;
        overflow: hidden;
        display: grid;
        align-content: start;
        gap: 1.1rem;
        border-radius: 28px;
        border: 1px solid var(--family-shell-border);
        background: linear-gradient(180deg, var(--family-shell-start), var(--family-shell-end));
        box-shadow:
            0 22px 52px var(--family-shadow),
            inset 0 1px 0 var(--family-shell-highlight);
        padding: clamp(1.05rem, 2.2vw, 1.35rem);
        min-width: 0;
    }

    .hearth-color-family::after {
        content: "";
        position: absolute;
        inset: auto -8% -18% 42%;
        height: 12rem;
        background: radial-gradient(circle at center, var(--family-accent), transparent 72%);
        opacity: 0.26;
        filter: blur(20px);
        pointer-events: none;
    }

    .hearth-color-family__header,
    .hearth-color-cluster {
        position: relative;
        z-index: 1;
    }

    .hearth-color-family__header {
        display: grid;
        gap: 0.42rem;
    }

    .hearth-color-family__mast {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .hearth-color-family__eyebrow {
        margin: 0;
        color: var(--family-label);
        font-family: var(--font-ui);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .hearth-color-family__rule {
        width: clamp(2.4rem, 9vw, 4.8rem);
        height: 1px;
        background: linear-gradient(90deg, var(--family-accent), transparent);
        opacity: 0.7;
    }

    .hearth-color-family__title {
        margin: 0;
        color: var(--family-heading);
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2vw, 1.6rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        max-width: 16ch;
    }

    .hearth-color-family__body {
        margin: 0;
        color: var(--family-body);
        font-size: 0.95rem;
        line-height: 1.72;
        max-width: 44ch;
    }

    .hearth-color-family__layout {
        display: grid;
        gap: 0.95rem;
        min-width: 0;
    }

    .hearth-color-cluster {
        display: grid;
        gap: 0.95rem;
        padding: 1rem;
        border-radius: 24px;
        border: 1px solid color-mix(in srgb, var(--family-shell-border) 86%, transparent);
        background:
            linear-gradient(
                180deg,
                color-mix(in srgb, var(--family-shell-start) 58%, transparent),
                color-mix(in srgb, var(--family-shell-end) 82%, transparent)
            );
    }

    .hearth-color-cluster__header {
        display: flex;
        align-items: center;
        gap: 0.7rem;
    }

    .hearth-color-section-label {
        margin: 0;
        color: var(--family-label);
        font-family: var(--font-ui);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .hearth-color-cluster__rule {
        flex: 1 1 auto;
        min-width: 2.4rem;
        height: 1px;
        background: linear-gradient(90deg, color-mix(in srgb, var(--family-accent) 58%, transparent), transparent);
        opacity: 0.68;
    }

    .hearth-color-surface-grid,
    .hearth-color-role-grid {
        display: grid;
        gap: 0.8rem;
        grid-auto-rows: 1fr;
    }

    .hearth-color-surface-card {
        min-height: 9.6rem;
        display: flex;
        flex-direction: column;
        gap: 0.78rem;
        border-radius: 18px;
        border: 1px solid var(--surface-border);
        background: var(--surface-bg);
        color: var(--surface-fg);
        padding: 0.95rem;
        box-shadow:
            inset 0 1px 0 var(--surface-highlight),
            0 14px 24px var(--surface-shadow);
    }

    .hearth-color-surface-card__meta,
    .hearth-color-role-card__meta {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: baseline;
        gap: 0.75rem;
    }

    .hearth-color-surface-card__name,
    .hearth-color-role-card__name {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-family: var(--font-ui);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .hearth-color-surface-card__hex,
    .hearth-color-role-card__hex {
        font-family: var(--font-code);
        font-size: 0.72rem;
        color: var(--surface-muted);
        white-space: nowrap;
    }

    .hearth-color-surface-card__swatch {
        min-height: 2.75rem;
        display: grid;
        align-content: center;
        gap: 0.48rem;
        padding: 0.72rem;
        border-radius: 14px;
        border: 1px solid color-mix(in srgb, var(--surface-border) 84%, transparent);
        background: color-mix(in srgb, var(--surface-bg) 88%, var(--surface-fg) 12%);
    }

    .hearth-color-surface-card__swatch-main,
    .hearth-color-surface-card__swatch-muted {
        display: block;
        height: 2px;
        border-radius: 999px;
    }

    .hearth-color-surface-card__swatch-main {
        width: 68%;
        background: var(--surface-fg);
    }

    .hearth-color-surface-card__swatch-muted {
        width: 42%;
        background: var(--surface-muted);
    }

    .hearth-color-surface-card__body,
    .hearth-color-role-card__body {
        margin: 0;
        min-height: 3.1em;
        overflow: hidden;
        display: -webkit-box;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        line-clamp: 2;
    }

    .hearth-color-surface-card__body {
        color: color-mix(in srgb, var(--surface-fg) 82%, transparent);
        font-size: 0.9rem;
        line-height: 1.56;
    }

    .hearth-color-role-card {
        min-height: 8.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.72rem;
        border-radius: 18px;
        border: 1px solid var(--family-role-border);
        background: var(--family-role-bg);
        padding: 0.9rem;
        box-shadow: inset 0 1px 0 var(--role-highlight);
    }

    .hearth-color-role-card__swatch {
        display: block;
        height: 0.72rem;
        border-radius: 999px;
        background:
            linear-gradient(
                90deg,
                color-mix(in srgb, var(--role-accent) 94%, transparent),
                color-mix(in srgb, var(--role-accent) 12%, transparent)
            );
        box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--role-accent) 18%, transparent);
    }

    .hearth-color-role-card__hex {
        color: var(--family-label);
