---
import { t, type Lang } from '../../i18n/utils'
import CodePreview from '../code/CodePreview.astro'
import { productData } from '../../data/product'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const brand = productData.product.wordmark
const docsUrl = lang === 'en' ? '/docs' : `/${lang}/docs`
const marketplaceUrl = productData.links.marketplaceUrl
const openVsxUrl = productData.links.openVsxUrl
const obsidianUrl = productData.links.releasesUrl
const githubUrl = productData.links.repositoryUrl
---

<section class="hearth-section relative overflow-hidden lg:min-h-[calc(100svh-92px)] flex items-center">
  <div class="hearth-shell">
    <div class="w-full py-3 sm:py-5 lg:py-7 grid items-start gap-6 lg:gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)] xl:grid-cols-[minmax(0,0.76fr)_minmax(0,1.24fr)]">
      <div data-reveal style="--reveal-delay: 60ms;" class="max-w-[560px]">
        <p
          data-reveal
          style="--reveal-delay: 90ms;"
          class="hearth-kicker hearth-kicker-accent inline-flex items-center gap-3 mb-6 sm:mb-8"
        >
          <span class="hearth-line"></span>
          {t(lang, 'hero.eyebrow')}
        </p>

        <h1
          data-reveal
          style="--reveal-delay: 150ms;"
          class="hearth-hero-title mb-6 sm:mb-8"
        >
          <span class="hearth-brand-main">{brand.primary}</span>
          {brand.secondary ? <span class="hearth-brand-accent ml-2 sm:ml-3">{brand.secondary}</span> : null}
        </h1>

        <p
          data-reveal
          style="--reveal-delay: 230ms;"
          class="hearth-copy hearth-subtitle hearth-hero-subtitle mb-7 sm:mb-9"
        >
          {t(lang, 'hero.subtitle')}
        </p>

        <div
          data-reveal
          style="--reveal-delay: 260ms;"
          class="mb-7 sm:mb-8 flex flex-wrap items-center gap-3"
        >
          <a
            href={docsUrl}
            class="hearth-btn-primary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
          >
            <span>{t(lang, 'hero.cta.system')}</span>
            <span aria-hidden="true">→</span>
          </a>
          <a
            href={openVsxUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hearth-btn-secondary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
          >
            <span>{t(lang, 'hero.cta.openvsx')}</span>
            <span aria-hidden="true">↗</span>
          </a>
          <a
            href={marketplaceUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hearth-btn-secondary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
          >
            <span>{t(lang, 'hero.cta.install')}</span>
            <span aria-hidden="true">↗</span>
          </a>
          <a
            href={obsidianUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hearth-btn-secondary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
          >
            <span>{t(lang, 'hero.cta.obsidian')}</span>
            <span aria-hidden="true">↗</span>
          </a>
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hearth-btn-tertiary inline-flex items-center gap-2 rounded-full border px-4 py-2.5 font-ui text-[0.8rem] font-semibold tracking-[0.02em]"
          >
            <span>{t(lang, 'hero.cta.star')}</span>
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <p data-reveal style="--reveal-delay: 300ms;" class="hearth-meta hearth-meta-muted">
          {t(lang, 'hero.cta.hint')}
        </p>
      </div>

      <div data-reveal style="--reveal-delay: 180ms;" class="lg:pt-7 xl:pt-8">
        <CodePreview lang={lang} compact={true} />
      </div>
    </div>
  </div>
</section>
