---
import { t, type Lang } from '../../i18n/utils'
import CodePreview from '../code/CodePreview.astro'
import { productData } from '../../data/product'
import { getDefaultThemeSelection, themePaletteCatalog, type ThemePaletteTheme } from '../../lib/themeFit'

interface Props {
  lang: Lang
}

const { lang } = Astro.props

function escapeJsonForScript(value: unknown): string {
  return JSON.stringify(value).replace(/</g, '\\u003c')
}

function localize(lang: Lang, key: string, fallback: string): string {
  const value = t(lang, key)
  return value === key ? fallback : value
}

function paletteStyle(theme: ThemePaletteTheme): string {
  const swatches = Object.fromEntries(theme.swatches.map((swatch) => [swatch.id, swatch.color]))
  return [
    `--pick-surface:${theme.surface}`,
    `--pick-ink:${theme.foreground}`,
    `--pick-accent:${theme.accent}`,
    `--pick-keyword:${swatches.keyword ?? theme.accent}`,
    `--pick-function:${swatches.function ?? theme.foreground}`,
    `--pick-property:${swatches.property ?? theme.foreground}`,
    `--pick-type:${swatches.type ?? theme.foreground}`,
  ].join(';')
}

function buildVscodeDevThemeUrl(itemName: string, label: string): string {
  return `https://vscode.dev/theme/${itemName}/${encodeURIComponent(label)}`
}

const installUrl = '#get-started'
const starUrl = productData.links.repositoryUrl
const heroWordmark = productData.product.wordmark
const defaultSelection = getDefaultThemeSelection()

const themes = themePaletteCatalog.map((theme) => ({
  id: theme.themeId,
  schemeId: theme.schemeId,
  variantId: theme.variantId,
  label: theme.label,
  summary: localize(lang, `fit.theme.${theme.themeId}.summary`, theme.summary),
  surface: theme.surface,
  foreground: theme.foreground,
  accent: theme.accent,
  swatches: theme.swatches,
  isDefault: theme.isDefault,
  isPublished: true,
}))

const flavors = productData.flavors
  .filter((flavor) => flavor.isPublished)
  .map((flavor) => {
    const representativeTheme =
      themes.find((theme) => theme.schemeId === flavor.id && theme.variantId === flavor.defaultVariant) ||
      themes.find((theme) => theme.schemeId === flavor.id) ||
      themes[0]

    return {
      id: flavor.id,
      label: flavor.shortName,
      summary: localize(lang, `fit.flavor.${flavor.id}.summary`, flavor.summary),
      representativeThemeId: representativeTheme.id,
    }
  })

const variants = Array.from(
  new Map(
    productData.extension.themeCatalog.map((theme) => [
      theme.variantId,
      {
        id: theme.variantId,
        label: localize(lang, `fit.climate.${theme.variantId}.label`, theme.climateLabel),
      },
    ]),
  ).values(),
)

const initialTheme =
  themes.find((theme) => theme.id === defaultSelection.themeId) ||
  themes.find((theme) => theme.isDefault) ||
  themes[0]
const tryUrl = buildVscodeDevThemeUrl(productData.extension.itemName, initialTheme.label)

const pickerData = {
  defaultSelection: {
    themeId: initialTheme.id,
    flavorId: initialTheme.schemeId,
    variantId: initialTheme.variantId,
  },
  themes,
  flavors,
  variants,
}

const pickerDataJson = escapeJsonForScript(pickerData)
---

<section class="hearth-section hearth-hero-section pt-6 sm:pt-8 pb-8 sm:pb-10" data-reveal>
  <div class="hearth-shell">
    <div
      class="hero-shell"
      data-hero-picker
      data-default-theme={initialTheme.id}
      data-vscode-item-name={productData.extension.itemName}
      style={paletteStyle(initialTheme)}
    >
      <script type="application/json" data-hero-catalog set:html={pickerDataJson}></script>

        <div class="hero-copy">
          <div class="hero-copy-top">
          <h1 class="hero-title">
            <span class="hero-title-primary">{heroWordmark.primary}</span>
            {heroWordmark.secondary ? <span class="hero-title-secondary">{heroWordmark.secondary}</span> : null}
          </h1>
          <p class="hero-subtitle hearth-copy hearth-copy-soft">
            {t(lang, 'hero.subtitle')}
          </p>
        </div>

        <div class="hero-actions">
          <a
            href={tryUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hearth-btn-primary hero-action"
            data-hero-vscode-link
            title={initialTheme.label}
            aria-label={`${t(lang, 'hero.cta.try')} — ${initialTheme.label}`}
          >
            {t(lang, 'hero.cta.try')}
          </a>
          <a href={installUrl} class="hearth-btn-secondary hero-action">
            {t(lang, 'hero.cta.installNow')}
          </a>
          <a
            href={starUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hearth-btn-tertiary hero-action"
          >
            {t(lang, 'hero.cta.star')}
          </a>
        </div>

        <div class="hero-controls">
          <div class="hero-control-row hero-control-row--flavor">
            <p class="hero-control-label">{t(lang, 'hero.quick.flavor')}</p>
            <div class="hero-control-body">
              <div class="hero-flavor-grid">
                {flavors.map((flavor) => {
                  const theme = themes.find((entry) => entry.id === flavor.representativeThemeId) || initialTheme
                  return (
                    <button
                      type="button"
                      class={`hero-flavor-card ${flavor.id === initialTheme.schemeId ? 'is-active' : ''}`}
                      data-hero-flavor
                      data-flavor-id={flavor.id}
                      aria-pressed={flavor.id === initialTheme.schemeId ? 'true' : 'false'}
                      style={paletteStyle(theme)}
                    >
                      <div class="hero-flavor-head">
                        <strong class="hero-flavor-name">{flavor.label}</strong>
                      </div>
                      <span class="hero-flavor-stripe" aria-hidden="true"></span>
                      <p class="hero-flavor-summary">{flavor.summary}</p>
                    </button>
                  )
                })}
              </div>
            </div>
          </div>

          <div class="hero-control-row hero-control-row--climate">
            <p class="hero-control-label">{t(lang, 'hero.quick.climate')}</p>
            <div class="hero-control-body">
              <div class="hero-climate-grid">
                {variants.map((variant) => {
                  const theme =
                    themes.find((entry) => entry.schemeId === initialTheme.schemeId && entry.variantId === variant.id) ||
                    initialTheme
                  return (
                    <button
                      type="button"
                      class={`hero-climate-card ${variant.id === initialTheme.variantId ? 'is-active' : ''}`}
                      data-hero-variant
                      data-variant-id={variant.id}
                      aria-pressed={variant.id === initialTheme.variantId ? 'true' : 'false'}
                      style={paletteStyle(theme)}
                    >
                      <span class="hero-climate-label">{variant.label}</span>
                    </button>
                  )
                })}
              </div>
            </div>
          </div>

          <div class="hero-control-row hero-control-row--current">
            <p class="hero-control-label">{t(lang, 'hero.quick.current')}</p>
            <div class="hero-control-body">
              <div class="hero-selection" data-hero-current style={paletteStyle(initialTheme)}>
                <div class="hero-selection-copy">
                  <strong class="hero-selection-title" data-hero-title>{initialTheme.label}</strong>
                  <p class="hero-selection-summary" data-hero-body>{initialTheme.summary}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-preview-shell">
        <div class="hero-preview">
          <CodePreview
            lang={lang}
            compact={true}
            showThemeTabs={false}
            autoCarousel={false}
            tabKeys={['ts', 'py', 'go', 'rs']}
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hearth-hero-section {
    position: relative;
  }

  .hearth-hero-section .hearth-shell {
    width: min(1360px, 100%);
  }

  .hero-shell {
    position: relative;
    display: grid;
    gap: clamp(1.45rem, 2.9vw, 2.1rem);
    padding: clamp(1.15rem, 2.8vw, 1.75rem);
    border: 1px solid color-mix(in srgb, var(--pick-accent) 16%, var(--hearth-card-border));
    border-radius: 18px;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-panel) 98%, black 2%),
        color-mix(in srgb, var(--hearth-panel-soft) 95%, black 5%)
      ),
      radial-gradient(circle at top left, color-mix(in srgb, var(--pick-accent) 5%, transparent), transparent 54%);
    box-shadow:
      0 18px 34px color-mix(in srgb, var(--hearth-shadow-024) 42%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 8%, transparent);
    transition:
      border-color 280ms var(--hearth-ease),
      background 320ms var(--hearth-ease),
      box-shadow 320ms var(--hearth-ease);
  }

  .hero-shell::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid color-mix(in srgb, var(--pick-accent) 7%, var(--hearth-paper-grid-soft));
    pointer-events: none;
    opacity: 1;
  }

  .hero-shell::after {
    display: none;
  }

  .hero-copy,
  .hero-preview-shell {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .hero-copy {
    display: grid;
    gap: 1.5rem;
    align-content: start;
    padding: 0.1rem 0 0.2rem;
  }

  .hero-copy-top {
    display: grid;
    gap: 0.72rem;
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 7vw, 5.35rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
    color: var(--hearth-ink-strong);
    display: grid;
    gap: 0;
    max-width: 8.2ch;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .hero-title-primary,
  .hero-title-secondary {
    display: block;
  }

  .hero-title-secondary {
    padding-left: clamp(0.18rem, 0.6vw, 0.5rem);
    color: color-mix(in srgb, var(--pick-accent) 56%, var(--hearth-ink-strong));
  }

  .hero-subtitle {
    margin: 0;
    max-width: 32rem;
    font-size: 1rem;
    line-height: 1.74;
    color: color-mix(in srgb, var(--hearth-text-body-soft) 94%, white 6%);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.52rem 0.84rem;
  }

  .hero-action {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.8rem;
    padding: 0.74rem 0.96rem;
    border-width: 1px;
    border-style: solid;
    border-radius: 10px;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 620;
    line-height: 1;
    text-decoration: none;
    box-shadow: none;
    transition:
      border-color 220ms var(--hearth-ease),
      background-color 220ms var(--hearth-ease),
      color 220ms var(--hearth-ease);
  }

  .hero-action:hover {
    transform: none;
  }

  .hero-action:active {
    transform: none;
  }

  .hero-controls {
    display: grid;
    gap: 0;
    padding-top: 1rem;
    border-top: 1px solid color-mix(in srgb, var(--pick-accent) 10%, var(--hearth-card-border));
  }

  .hero-control-row {
    display: grid;
    gap: 0.55rem;
    padding-block: 0.82rem;
    border-top: 1px solid color-mix(in srgb, var(--pick-accent) 7%, var(--hearth-card-border));
  }

  .hero-control-row:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .hero-control-body {
    min-width: 0;
  }

  .hero-control-label {
    margin: 0;
    color: color-mix(in srgb, var(--pick-accent) 34%, var(--hearth-metric-muted));
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.4;
  }

  .hero-flavor-grid {
    display: grid;
    gap: 0;
  }

  .hero-flavor-card,
  .hero-climate-card,
  .hero-selection {
    position: relative;
    overflow: hidden;
  }

  .hero-flavor-card,
  .hero-climate-card {
    width: 100%;
    text-align: left;
    transition:
      transform 220ms var(--hearth-ease),
      border-color 220ms var(--hearth-ease),
      background-color 220ms var(--hearth-ease),
      color 220ms var(--hearth-ease),
      opacity 220ms var(--hearth-ease);
  }

  .hero-flavor-card::before,
  .hero-climate-card::before,
  .hero-selection::before {
    display: none;
  }

  .hero-flavor-card {
    display: grid;
    gap: 0.52rem;
    min-height: auto;
    padding: 1.02rem 0 1.02rem 1rem;
    border: 0;
    border-top: 1px solid color-mix(in srgb, var(--hearth-card-border) 84%, transparent);
    border-left: 2px solid transparent;
    border-radius: 0;
    text-align: left;
    background: transparent;
    box-shadow: none;
  }

  .hero-flavor-card::after {
    content: "";
    position: absolute;
    left: -1px;
    top: 0.7rem;
    bottom: 0.7rem;
    width: 2px;
    background: var(--pick-accent);
    opacity: 0;
    transform: scaleY(0.35);
    transform-origin: center;
    transition:
      opacity 220ms var(--hearth-ease),
      transform 220ms var(--hearth-ease);
  }

  .hero-flavor-grid > :first-child {
    border-top: 0;
  }

  .hero-flavor-card:hover {
    background: color-mix(in srgb, var(--pick-accent) 7%, transparent);
    transform: translateX(4px);
  }

  .hero-flavor-card:hover::after {
    opacity: 0.72;
    transform: scaleY(1);
  }

  .hero-flavor-card.is-active {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--pick-accent) 10%, transparent),
      transparent 72%
    );
    border-left-color: var(--pick-accent);
  }

  .hero-flavor-card.is-active::after {
    opacity: 1;
    transform: scaleY(1);
  }

  .hero-flavor-head {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.6rem;
  }

  .hero-flavor-name,
  .hero-selection-title {
    color: var(--hearth-ink-strong);
    font-family: var(--font-ui);
    font-weight: 700;
  }

  .hero-flavor-name {
    font-size: 1.08rem;
    letter-spacing: -0.01em;
  }

  .hero-flavor-stripe {
    display: block;
    width: 7.4rem;
    height: 0.22rem;
    border-radius: 9999px;
    background:
      linear-gradient(
        90deg,
        var(--pick-keyword),
        var(--pick-function) 54%,
        var(--pick-property)
      );
    transition: width 220ms var(--hearth-ease), opacity 220ms var(--hearth-ease);
  }

  .hero-flavor-summary {
    margin: 0;
    color: color-mix(in srgb, var(--hearth-ink-soft) 94%, white 6%);
    font-size: 0.95rem;
    line-height: 1.58;
    max-width: 28rem;
  }

  .hero-flavor-card:hover .hero-flavor-name,
  .hero-flavor-card.is-active .hero-flavor-name {
    color: var(--hearth-ink-strong);
  }

  .hero-flavor-card:hover .hero-flavor-summary,
  .hero-flavor-card.is-active .hero-flavor-summary {
    color: color-mix(in srgb, var(--hearth-ink-soft) 84%, white 16%);
  }

  .hero-flavor-card:hover .hero-flavor-stripe,
  .hero-flavor-card.is-active .hero-flavor-stripe {
    width: 8.5rem;
    opacity: 1;
  }

  .hero-climate-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.52rem;
  }

  .hero-climate-card {
    width: auto;
    min-height: auto;
    padding: 0.58rem 0.88rem;
    border: 1px solid color-mix(in srgb, var(--hearth-card-border) 88%, transparent);
    border-radius: 10px;
    background: transparent;
    box-shadow: none;
    transition:
      transform 180ms var(--hearth-ease),
      border-color 220ms var(--hearth-ease),
      background-color 220ms var(--hearth-ease),
      box-shadow 220ms var(--hearth-ease);
  }

  .hero-climate-label {
    color: var(--hearth-ink-soft);
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 620;
    letter-spacing: 0.01em;
  }

  .hero-climate-card:hover {
    border-color: color-mix(in srgb, var(--pick-accent) 32%, var(--hearth-card-border));
    background: color-mix(in srgb, var(--pick-accent) 6%, transparent);
    transform: translateY(-1px);
  }

  .hero-climate-card.is-active {
    border-color: color-mix(in srgb, var(--pick-accent) 48%, var(--hearth-card-border));
    background: color-mix(in srgb, var(--pick-accent) 10%, transparent);
    box-shadow: inset 0 -2px 0 color-mix(in srgb, var(--pick-accent) 82%, transparent);
  }

  .hero-climate-card.is-active .hero-climate-label {
    color: var(--hearth-ink-strong);
  }

  .hero-selection {
    display: grid;
    gap: 0.36rem;
    padding: 1rem 0 0.2rem 1rem;
    border: 0;
    border-left: 2px solid color-mix(in srgb, var(--pick-accent) 76%, transparent);
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .hero-selection::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--pick-accent) 12%, transparent),
      transparent 56%
    );
    opacity: 0;
    pointer-events: none;
  }

  .hero-selection.is-refreshing::after {
    animation: hero-selection-flash 360ms var(--hearth-ease);
  }

  .hero-selection-copy {
    display: grid;
    gap: 0.34rem;
  }

  .hero-selection-title {
    font-size: 1.08rem;
  }

  .hero-selection-summary {
    margin: 0;
    color: color-mix(in srgb, var(--hearth-ink-soft) 90%, white 10%);
    font-size: 0.95rem;
    line-height: 1.58;
  }

  .hero-preview-shell {
    display: grid;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .hero-preview {
    min-width: 0;
  }

  .hero-preview :global(.code-preview-root) {
    border-color: color-mix(in srgb, var(--pick-accent) 14%, var(--hearth-card-border));
    border-radius: 14px;
    box-shadow:
      0 18px 32px color-mix(in srgb, var(--hearth-shadow-024) 34%, transparent),
      inset 0 1px 0 color-mix(in srgb, white 6%, transparent);
  }

  .hero-preview :global(.code-preview-root::before) {
    display: none;
  }

  .hero-preview :global(.preview-stage--compact) {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--hearth-preview-stage-grad-start) 82%, black 18%),
        color-mix(in srgb, var(--hearth-preview-stage-grad-end) 72%, black 28%)
      );
  }

  .hero-preview :global(.preview-toolbar) {
    padding-block: 0.56rem;
    padding-inline: 0.7rem;
  }

  .hero-preview :global(.preview-display) {
    min-height: clamp(420px, 55svh, 560px);
  }

  .hero-preview :global(.preview-stage--compact .shiki-wrap) {
    max-height: clamp(360px, 48svh, 500px);
    -webkit-mask-image: linear-gradient(180deg, black 0%, black 91%, transparent 100%);
    mask-image: linear-gradient(180deg, black 0%, black 91%, transparent 100%);
  }

  @media (min-width: 980px) {
    .hero-shell {
      grid-template-columns: minmax(430px, 0.82fr) minmax(560px, 1.18fr);
      gap: 2.2rem;
    }

    .hero-copy {
      padding-right: 1.2rem;
    }

    .hero-preview-shell::before {
      content: "";
      position: absolute;
      left: -0.96rem;
      top: 0;
      bottom: 0;
      width: 1px;
      background: linear-gradient(
        180deg,
        transparent,
        color-mix(in srgb, var(--pick-accent) 16%, var(--hearth-card-border)) 10%,
        color-mix(in srgb, var(--pick-accent) 16%, var(--hearth-card-border)) 90%,
        transparent
      );
      opacity: 0.9;
      pointer-events: none;
    }
  }

  @media (max-width: 979px) {
    .hero-preview-shell {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .hero-shell {
      padding: 0.95rem;
      border-radius: 14px;
    }

    .hero-shell::before {
      border-radius: inherit;
    }

    .hero-actions {
      gap: 0.48rem;
    }

    .hero-action {
      width: auto;
    }

    .hero-control-label {
      font-size: 0.76rem;
    }

    .hero-flavor-grid,
    .hero-climate-grid {
      grid-template-columns: 1fr;
    }

    .hero-flavor-card,
    .hero-climate-card,
    .hero-selection {
      border-radius: 0;
    }

    .hero-preview :global(.preview-display) {
      min-height: clamp(280px, 37svh, 360px);
    }

    .hero-preview :global(.preview-stage--compact .shiki-wrap) {
      max-height: clamp(210px, 30svh, 290px);
    }
  }

  @keyframes hero-selection-flash {
    0% {
      opacity: 0;
      transform: translateX(-4px);
    }

    28% {
      opacity: 0.95;
      transform: translateX(0);
    }

    100% {
      opacity: 0;
      transform: translateX(0);
    }
  }
</style>

<script>
  document.querySelectorAll('[data-hero-picker]').forEach((root) => {
    type SwatchId = 'surface' | 'keyword' | 'function' | 'property' | 'type'

    type ThemeData = {
      id: string
      schemeId: string
      variantId: string
      label: string
      summary: string
      isPublished: boolean
      surface: string
      foreground: string
      accent: string
      swatches: Array<{ id: SwatchId; color: string }>
    }

    type FlavorData = {
      id: string
      label: string
      summary: string
      representativeThemeId: string
    }

    type VariantData = {
      id: string
      label: string
    }

    type PickerData = {
      defaultSelection: {
        themeId: string
        flavorId: string
        variantId: string
      }
      themes: ThemeData[]
      flavors: FlavorData[]
      variants: VariantData[]
    }

    const catalogEl = root.querySelector('[data-hero-catalog]')
    if (!catalogEl?.textContent) return

    const data = JSON.parse(catalogEl.textContent) as PickerData
    let selectedFlavorId = data.defaultSelection.flavorId || data.flavors[0]?.id || ''
    let selectedVariantId = data.defaultSelection.variantId || data.variants[0]?.id || ''
    let selectedThemeId = data.defaultSelection.themeId || data.themes[0]?.id || ''

    const flavorButtons = Array.from(root.querySelectorAll('[data-hero-flavor]'))
    const variantButtons = Array.from(root.querySelectorAll('[data-hero-variant]'))
    const titleEl = root.querySelector('[data-hero-title]')
    const bodyEl = root.querySelector('[data-hero-body]')
    const currentEl = root.querySelector('[data-hero-current]')
    const vscodeLinkEl = root.querySelector('[data-hero-vscode-link]')
    const vscodeItemName = root.getAttribute('data-vscode-item-name') || ''
    let currentFlashTimer = 0

    const getTheme = (themeId: string) => data.themes.find((theme) => theme.id === themeId) || data.themes[0]
    const getFlavor = (flavorId: string) => data.flavors.find((flavor) => flavor.id === flavorId) || data.flavors[0]
    const getThemeByFlavorVariant = (flavorId: string, variantId: string) => (
      data.themes.find((theme) => theme.schemeId === flavorId && theme.variantId === variantId)
      || data.themes.find((theme) => theme.schemeId === flavorId)
      || data.themes[0]
    )
    const buildVscodeDevUrl = (theme: ThemeData) => (
      vscodeItemName
        ? `https://vscode.dev/theme/${vscodeItemName}/${encodeURIComponent(theme.label)}`
        : '#'
    )

    const applyPaletteVars = (el: Element | null, theme: ThemeData) => {
      if (!(el instanceof HTMLElement)) return
      const swatches = Object.fromEntries(theme.swatches.map((swatch) => [swatch.id, swatch.color]))
      el.style.setProperty('--pick-surface', theme.surface)
      el.style.setProperty('--pick-ink', theme.foreground)
      el.style.setProperty('--pick-accent', theme.accent)
      el.style.setProperty('--pick-keyword', swatches.keyword || theme.accent)
      el.style.setProperty('--pick-function', swatches.function || theme.foreground)
      el.style.setProperty('--pick-property', swatches.property || theme.foreground)
      el.style.setProperty('--pick-type', swatches.type || theme.foreground)
    }

    const flashCurrent = () => {
      if (!(currentEl instanceof HTMLElement)) return
      currentEl.classList.remove('is-refreshing')
      window.clearTimeout(currentFlashTimer)
      window.requestAnimationFrame(() => {
        currentEl.classList.add('is-refreshing')
        currentFlashTimer = window.setTimeout(() => {
          currentEl.classList.remove('is-refreshing')
        }, 380)
      })
    }

    const sync = () => {
      const theme = getThemeByFlavorVariant(selectedFlavorId, selectedVariantId)
      selectedThemeId = theme.id
      selectedFlavorId = theme.schemeId
      selectedVariantId = theme.variantId

      applyPaletteVars(root, theme)

      flavorButtons.forEach((button) => {
        const flavorId = button.getAttribute('data-flavor-id') || ''
        const flavor = getFlavor(flavorId)
        const representativeTheme = getTheme(flavor.representativeThemeId)
        const isActive = flavorId === selectedFlavorId
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false')
        applyPaletteVars(button, representativeTheme)
      })

      variantButtons.forEach((button) => {
        const variantId = button.getAttribute('data-variant-id') || ''
        const variantTheme = getThemeByFlavorVariant(selectedFlavorId, variantId)
        const isActive = variantId === selectedVariantId
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false')
        applyPaletteVars(button, variantTheme)
      })

      applyPaletteVars(currentEl, theme)
      flashCurrent()

      if (titleEl instanceof HTMLElement) titleEl.textContent = theme.label
      if (bodyEl instanceof HTMLElement) bodyEl.textContent = theme.summary
      if (vscodeLinkEl instanceof HTMLAnchorElement) {
        const href = buildVscodeDevUrl(theme)
        vscodeLinkEl.href = href
        vscodeLinkEl.title = theme.label
        vscodeLinkEl.setAttribute('aria-label', `${vscodeLinkEl.textContent || 'Try in vscode.dev'} — ${theme.label}`)
      }

      window.dispatchEvent(
        new CustomEvent('theme-fit-preview', {
          detail: {
            themeId: selectedThemeId,
          },
        }),
      )
    }

    flavorButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const flavorId = button.getAttribute('data-flavor-id')
        if (!flavorId) return
        selectedFlavorId = flavorId
        sync()
      })
    })

    variantButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const variantId = button.getAttribute('data-variant-id')
        if (!variantId) return
        selectedVariantId = variantId
        sync()
      })
    })

    sync()
  })
</script>
