---
import { t, type Lang } from '../../i18n/utils'
import { productData } from '../../data/product'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const releaseVersion = `v${productData.release.version}`
const docsUrl = lang === 'en' ? '/docs' : `/${lang}/docs`
const marketplaceUrl = productData.links.marketplaceUrl
const openVsxUrl = productData.links.openVsxUrl
const obsidianUrl = productData.links.releasesUrl
const githubUrl = productData.links.repositoryUrl
---

<section class="hearth-section hearth-tail-wrap">
  <div class="hearth-shell">
    <div data-reveal class="hearth-tail-content">
      <p class="hearth-kicker hearth-kicker-accent mb-4 flex items-center gap-3">
        {t(lang, 'final.label')}
        <span class="hearth-line"></span>
      </p>

      <h2 class="hearth-heading-strong text-[1.7rem] sm:text-[2.1rem] leading-[1.15] tracking-[-0.015em] font-semibold mb-3">
        {t(lang, 'final.title')}
      </h2>

      <p class="hearth-copy hearth-copy-muted max-w-[60ch] mb-7">
        {t(lang, 'final.subtitle')}
      </p>

      <div class="mb-6 flex flex-wrap items-center gap-3">
        <a
          href={docsUrl}
          class="hearth-btn-primary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
        >
          <span>{t(lang, 'hero.cta.system')}</span>
          <span aria-hidden="true">→</span>
        </a>
        <a
          href={openVsxUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hearth-btn-secondary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
        >
          <span>{t(lang, 'hero.cta.openvsx')}</span>
          <span aria-hidden="true">↗</span>
        </a>
        <a
          href={marketplaceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hearth-btn-secondary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
        >
          <span>{t(lang, 'hero.cta.install')}</span>
          <span aria-hidden="true">↗</span>
        </a>
        <a
          href={obsidianUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hearth-btn-secondary inline-flex items-center gap-2 rounded-full border px-5 py-2.5 font-ui text-[0.84rem] font-semibold tracking-[0.02em]"
        >
          <span>{t(lang, 'hero.cta.obsidian')}</span>
          <span aria-hidden="true">↗</span>
        </a>
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hearth-btn-tertiary inline-flex items-center gap-2 rounded-full border px-4 py-2.5 font-ui text-[0.8rem] font-semibold tracking-[0.02em]"
        >
          <span>{t(lang, 'hero.cta.star')}</span>
          <span aria-hidden="true">↗</span>
        </a>
      </div>

      <p class="hearth-meta hearth-meta-muted flex flex-wrap items-center gap-x-2 gap-y-1">
        <span>{t(lang, 'final.meta.primary')}</span>
        <span aria-hidden="true">·</span>
        <span>{t(lang, 'final.meta.secondary')}</span>
        <span aria-hidden="true">·</span>
        <span>{t(lang, 'final.meta.release')} {releaseVersion}</span>
      </p>
    </div>
  </div>
</section>
