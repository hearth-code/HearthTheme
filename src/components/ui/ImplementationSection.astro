---
import { t, type Lang } from "../../i18n/utils";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;

const items = [
	{
		nameKey: "platform.item.core.name",
		statusKey: "platform.item.core.status",
		bodyKey: "platform.item.core.body",
	},
	{
		nameKey: "platform.item.vsx.name",
		statusKey: "platform.item.vsx.status",
		bodyKey: "platform.item.vsx.body",
	},
	{
		nameKey: "platform.item.vscode.name",
		statusKey: "platform.item.vscode.status",
		bodyKey: "platform.item.vscode.body",
	},
	{
		nameKey: "platform.item.obsidian.name",
		statusKey: "platform.item.obsidian.status",
		bodyKey: "platform.item.obsidian.body",
	},
];
---

<section class="hearth-section hearth-section-y" data-reveal>
	<div class="hearth-shell">
		<div class="hearth-intro">
			<p class="hearth-kicker mb-4 flex items-center gap-3">
				{t(lang, "platform.label")}
				<span class="hearth-line"></span>
			</p>
			<h2 class="hearth-heading text-[1.9rem] sm:text-[2.25rem] leading-[1.18] tracking-[-0.015em] font-semibold mb-4">
				{t(lang, "platform.title")}
			</h2>
			<p class="hearth-copy hearth-copy-soft max-w-[920px] mb-8">
				{t(lang, "platform.subtitle")}
			</p>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
			{
				items.map(({ nameKey, statusKey, bodyKey }, index) => (
					<article
						data-reveal
						style={`--reveal-delay: ${80 + index * 60}ms;`}
						class="hearth-proof-variant-card rounded-xl px-4 py-4 min-w-0"
					>
						<p class="hearth-meta hearth-kicker-accent mb-2">{t(lang, statusKey)}</p>
						<h3 class="hearth-proof-variant-title font-ui text-[1rem] font-semibold mb-2">{t(lang, nameKey)}</h3>
						<p class="hearth-proof-variant-body hearth-copy text-[0.98rem] leading-[1.7]">{t(lang, bodyKey)}</p>
					</article>
				))
			}
		</div>
	</div>
</section>
