---
import { t, type Lang } from '../../i18n/utils'

interface Props {
  lang: Lang
}

const { lang } = Astro.props

const cards = [
  { num: '01', titleKey: 'philosophy.01.title', bodyKey: 'philosophy.01.body' },
  { num: '02', titleKey: 'philosophy.02.title', bodyKey: 'philosophy.02.body' },
  { num: '03', titleKey: 'philosophy.03.title', bodyKey: 'philosophy.03.body' },
  { num: '04', titleKey: 'philosophy.04.title', bodyKey: 'philosophy.04.body' },
]
---

<section class="hearth-section hearth-section-y" data-reveal>
  <div class="hearth-shell">
    <div class="hearth-intro">
      <p class="hearth-kicker mb-5 flex items-center gap-3">
        {t(lang, 'philosophy.label')}
        <span class="hearth-line"></span>
      </p>
    </div>

    <div class="hearth-feature-grid">
      {cards.map(({ num, titleKey, bodyKey }, index) => (
        <article
          data-reveal
          style={`--reveal-delay: ${90 + index * 70}ms;`}
          class="hearth-feature-item"
        >
          <div class="hearth-feature-index">{num}</div>
          <h3 class="hearth-feature-title">{t(lang, titleKey)}</h3>
          <p class="hearth-copy hearth-feature-body">{t(lang, bodyKey)}</p>
        </article>
      ))}
    </div>
  </div>
</section>
