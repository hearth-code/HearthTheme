				</div>
			</section>

			<section class="hearth-surface hearth-card p-6 sm:p-8">
				<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.82rem] hearth-doc-heading mb-6">{c.matrixTitle}</h2>
				<div class="md:hidden grid gap-3">
					{
						semanticRows.map((row) => (
							<article class="hearth-surface hearth-surface-soft hearth-card border hearth-doc-divider bg-[var(--hearth-surface-soft-bg)] p-4">
								<div class="mb-2">
									<h3 class="hearth-doc-heading font-mono text-[13px] mb-1">{row.role}</h3>
									<p class="hearth-doc-note text-[0.94rem] leading-relaxed">{row.note}</p>
								</div>
								<div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
									{[
										{ label: c.dark, value: row.dark },
										{ label: c.darkSoft, value: row.darkSoft },
										{ label: c.light, value: row.light },
										{ label: c.lightSoft, value: row.lightSoft },
									].map((variant) => (
										<div class="min-w-0 border hearth-doc-divider rounded-sm bg-[var(--hearth-grid-line-soft)] px-2.5 py-2">
											<p class="hearth-meta mb-1">{variant.label}</p>
											<span class="inline-flex items-center gap-2 font-mono text-[12px] hearth-doc-mono">
												<span class="inline-block w-3 h-3 rounded-sm border hearth-doc-swatch" style={`background: ${variant.value}`}></span>
												{variant.value}
											</span>
										</div>
									))}
								</div>
							</article>
						))
					}
				</div>
				<div class="hidden md:block overflow-x-auto">
					<table class="hearth-table text-[0.95rem] min-w-[980px]">
						<thead>
							<tr>
								<th class="hearth-meta">{c.role}</th>
								<th class="hearth-meta">{c.dark}</th>
								<th class="hearth-meta">{c.darkSoft}</th>
								<th class="hearth-meta">{c.light}</th>
								<th class="hearth-meta">{c.lightSoft}</th>
								<th class="hearth-meta">{c.narrative}</th>
							</tr>
						</thead>
						<tbody>
							{
								semanticRows.map((row) => (
									<tr>
										<td class="hearth-doc-heading font-mono text-[12.5px]">{row.role}</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.dark}`}></span>
												{row.dark}
											</span>
										</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.darkSoft}`}></span>
												{row.darkSoft}
											</span>
										</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.light}`}></span>
												{row.light}
											</span>
										</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.lightSoft}`}></span>
												{row.lightSoft}
											</span>
										</td>
										<td class="hearth-doc-note min-w-[16rem]">{row.note}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
			</section>

			<section class="grid lg:grid-cols-2 gap-7 sm:gap-8">
				<div class="hearth-surface hearth-card p-6 sm:p-8">
					<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.76rem] hearth-doc-heading mb-6">{c.budgetTitle}</h2>
					<div class="overflow-x-auto">
						<table class="hearth-table text-[0.95rem] min-w-[420px]">
							<thead>
								<tr>
									<th class="hearth-meta">{c.budgetMetric}</th>
									<th class="hearth-meta">{c.budgetTarget}</th>
								</tr>
							</thead>
							<tbody>
								{
									budgetRows.map((row) => (
										<tr>
											<td class="hearth-doc-mono">{row.metric}</td>
											<td class="hearth-doc-heading font-mono text-[12.5px]">{row.target}</td>
										</tr>
									))
								}
							</tbody>
						</table>
					</div>
				</div>

				<div class="hearth-surface hearth-card p-6 sm:p-8">
					<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.76rem] hearth-doc-heading mb-6">{c.snapshotTitle}</h2>
					<ul class="space-y-3 text-[0.95rem]">
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark fg/bg</span>
							<span class="font-mono hearth-doc-heading">{snapshot.darkFgBg}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark soft fg/bg</span>
							<span class="font-mono hearth-doc-heading">{snapshot.darkSoftFgBg}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">light fg/bg</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightFgBg}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">light soft fg/bg</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightSoftFgBg}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark comment</span>
							<span class="font-mono hearth-doc-heading">{snapshot.darkComment}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark soft comment</span>
							<span class="font-mono hearth-doc-heading">{snapshot.darkSoftComment}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">light comment</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightComment}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">light soft comment</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightSoftComment}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark operator</span>
							<span class="font-mono hearth-doc-heading">{snapshot.darkOperator}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark soft operator</span>
							<span class="font-mono hearth-doc-heading">{snapshot.darkSoftOperator}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">light operator</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightOperator}</span>
						</li>
						<li class="flex items-center justify-between">
							<span class="hearth-doc-note">light soft operator</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightSoftOperator}</span>
						</li>
					</ul>
				</div>
			</section>

			<section class="hearth-surface hearth-card p-6 sm:p-8">
				<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.76rem] hearth-doc-heading mb-2">{c.changelogTitle}</h2>
				<div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
					<p class="hearth-copy hearth-doc-date text-[0.98rem]">{c.changelogSubtitle}</p>
					<a
						href={changelogUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="hearth-footer-link text-[0.78rem]"
					>
						{c.changelogFullLink}
					</a>
				</div>
				{
					changelogRows.length === 0 ? (
						<p class="hearth-copy hearth-doc-body text-[0.98rem]">{c.noReleaseNotes}</p>
					) : (
						<div class="grid gap-4">
							{
								changelogPreviewRows.map((entry) => (
									<article class="hearth-surface hearth-surface-soft hearth-card p-6">
										<div class="flex items-center justify-between gap-4 mb-3">
											<span class="font-mono text-[12.5px] hearth-doc-heading">{entry.version}</span>
											{entry.date ? (
												<span class="font-mono text-[11px] hearth-doc-date">{entry.date}</span>
											) : null}
										</div>
										<h3 class="font-ui font-semibold tracking-[-0.014em] text-[1.34rem] hearth-doc-heading mb-2">{c.releasePrefix} {entry.version}</h3>
										<p class="hearth-copy hearth-doc-body text-[1.01rem] leading-relaxed mb-3">{entry.summary}</p>
										{
											entry.changes.length > 0 ? (
												<ul class="space-y-1.5 hearth-doc-bullet text-[0.99rem] leading-relaxed hearth-copy">
													{entry.changes.slice(0, CHANGELOG_VISIBLE_CHANGES).map((line) => <li>• {line}</li>)}
												</ul>
											) : null
										}
										{
											entry.changes.length > CHANGELOG_VISIBLE_CHANGES ? (
												<p class="hearth-copy hearth-doc-date text-[0.88rem] mt-3">
													+ {entry.changes.length - CHANGELOG_VISIBLE_CHANGES} {c.changelogMoreChangesLabel}
												</p>
											) : null
										}
									</article>
								))
							}
						</div>
					)
				}
			</section>
		</div>
	</div>
</section>
