const c = copy[lang];
const changelogRows = readExtensionChangelogRows();

const semanticRows = [
	{ role: "background", dark: d.bg, darkSoft: s.bg, light: l.bg, lightSoft: ls.bg, note: c.roles.background },
	{ role: "foreground", dark: d.fg, darkSoft: s.fg, light: l.fg, lightSoft: ls.fg, note: c.roles.foreground },
	{ role: "keyword", dark: d.keyword, darkSoft: s.keyword, light: l.keyword, lightSoft: ls.keyword, note: c.roles.keyword },
	{ role: "operator", dark: d.operator, darkSoft: s.operator, light: l.operator, lightSoft: ls.operator, note: c.roles.operator },
	{ role: "function", dark: d.fn, darkSoft: s.fn, light: l.fn, lightSoft: ls.fn, note: c.roles.function },
	{ role: "string", dark: d.string, darkSoft: s.string, light: l.string, lightSoft: ls.string, note: c.roles.string },
	{ role: "number", dark: d.number, darkSoft: s.number, light: l.number, lightSoft: ls.number, note: c.roles.number },
	{ role: "type", dark: d.type, darkSoft: s.type, light: l.type, lightSoft: ls.type, note: c.roles.type },
	{ role: "variable", dark: d.variable, darkSoft: s.variable, light: l.variable, lightSoft: ls.variable, note: c.roles.variable },
	{ role: "comment", dark: d.comment, darkSoft: s.comment, light: l.comment, lightSoft: ls.comment, note: c.roles.comment },
];

const budgetRows = [
	{ metric: "Editor fg/bg contrast", target: ">= 7.0" },
	{ metric: "Comment contrast", target: "2.2 - 4.2" },
	{ metric: "Operator contrast", target: "2.8 - 6.2" },
	{ metric: "Role separation deltaE", target: ">= 10" },
	{ metric: "Cross-theme hue drift", target: "<= 45°" },
];

function hexToRgb(hex: string) {
	const raw = hex.slice(1);
	return [
		Number.parseInt(raw.slice(0, 2), 16),
		Number.parseInt(raw.slice(2, 4), 16),
		Number.parseInt(raw.slice(4, 6), 16),
	];
}

function toLinear(channel: number) {
	const c = channel / 255;
	return c <= 0.03928 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
}

function contrastRatio(a: string, b: string) {
	const [ar, ag, ab] = hexToRgb(a).map(toLinear);
	const [br, bg, bb] = hexToRgb(b).map(toLinear);
	const la = 0.2126 * ar + 0.7152 * ag + 0.0722 * ab;
	const lb = 0.2126 * br + 0.7152 * bg + 0.0722 * bb;
	const hi = Math.max(la, lb);
	const lo = Math.min(la, lb);
	return ((hi + 0.05) / (lo + 0.05)).toFixed(1);
}

const snapshot = {
	darkFgBg: contrastRatio(d.fg, d.bg),
	darkSoftFgBg: contrastRatio(s.fg, s.bg),
	lightFgBg: contrastRatio(l.fg, l.bg),
	lightSoftFgBg: contrastRatio(ls.fg, ls.bg),
	darkComment: contrastRatio(d.comment, d.bg),
	darkSoftComment: contrastRatio(s.comment, s.bg),
	lightComment: contrastRatio(l.comment, l.bg),
	lightSoftComment: contrastRatio(ls.comment, ls.bg),
	darkOperator: contrastRatio(d.operator, d.bg),
	darkSoftOperator: contrastRatio(s.operator, s.bg),
	lightOperator: contrastRatio(l.operator, l.bg),
	lightSoftOperator: contrastRatio(ls.operator, ls.bg),
};
