							<span class="hearth-doc-note">light soft comment</span>
							<span class="font-mono hearth-doc-heading">{snapshot.lightSoftComment}</span>
						</li>
						<li class="flex items-center justify-between border-b hearth-doc-divider pb-2">
							<span class="hearth-doc-note">dark operator</span>
