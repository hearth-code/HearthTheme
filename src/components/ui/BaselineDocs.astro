										</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.darkSoft}`}></span>
												{row.darkSoft}
											</span>
										</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.light}`}></span>
												{row.light}
											</span>
										</td>
										<td>
											<span class="inline-flex items-center gap-2 font-mono text-[12.5px] hearth-doc-mono">
												<span class="inline-block w-3.5 h-3.5 rounded-sm border hearth-doc-swatch" style={`background: ${row.lightSoft}`}></span>
												{row.lightSoft}
											</span>
										</td>
										<td class="hearth-doc-note">{row.note}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>
			</section>

			<section class="grid lg:grid-cols-2 gap-7 sm:gap-8">
				<div class="hearth-surface hearth-card p-6 sm:p-8">
					<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.76rem] hearth-doc-heading mb-6">{c.budgetTitle}</h2>
					<table class="hearth-table text-[0.95rem]">
