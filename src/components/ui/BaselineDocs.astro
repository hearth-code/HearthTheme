---
import { readFileSync } from "node:fs";
import { tokens } from "../../data/tokens";
import type { Lang } from "../../i18n/utils";

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const d = tokens.dark;
const s = tokens.darkSoft;
const l = tokens.light;
const ls = tokens.lightSoft;
const changelogUrl = "https://github.com/hearth-code/HearthTheme/blob/main/extension/CHANGELOG.md";
const CHANGELOG_VISIBLE_RELEASES = 6;
const CHANGELOG_VISIBLE_CHANGES = 2;

interface ExtensionReleaseRow {
	version: string;
	date: string;
	summary: string;
	changes: string[];
}

function parseExtensionChangelog(markdown: string): ExtensionReleaseRow[] {
	const rows: ExtensionReleaseRow[] = [];
	const normalized = markdown.replace(/\r\n/g, "\n");
	const sections = normalized.split(/\n(?=##\s+)/g);

	for (const section of sections) {
		const headerMatch = section.match(/^##\s+(\d+\.\d+\.\d+)(?:\s*-\s*(\d{4}-\d{2}-\d{2}))?/m);
		if (!headerMatch) continue;

		const [, version, date = ""] = headerMatch;
		const bullets = [...section.matchAll(/^- (.+)$/gm)].map((match) => match[1].trim()).filter(Boolean);
		if (bullets.length === 0) continue;

		const [summary, ...rest] = bullets;
		rows.push({
			version,
			date,
			summary,
			changes: rest,
		});
	}

	return rows;
}

function readExtensionChangelogRows(): ExtensionReleaseRow[] {
	try {
		const changelogPath = new URL("../../../extension/CHANGELOG.md", import.meta.url);
		const content = readFileSync(changelogPath, "utf8");
		return parseExtensionChangelog(content);
	} catch {
		return [];
	}
}

