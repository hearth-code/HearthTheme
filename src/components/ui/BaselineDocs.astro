							>
								<p class="hearth-doc-heading font-ui font-semibold tracking-[-0.014em] text-[1.18rem] mb-2">{card.title}</p>
								<p class="hearth-copy hearth-doc-note text-[0.97rem] leading-relaxed mb-4">{card.body}</p>
								<span class="hearth-footer-link text-[0.78rem]">{c.openDoc}</span>
