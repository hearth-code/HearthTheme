			<section class="hearth-surface hearth-card p-6 sm:p-8">
				<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.76rem] hearth-doc-heading mb-2">{c.changelogTitle}</h2>
				<p class="hearth-copy hearth-doc-date text-[0.98rem] mb-6">{c.changelogSubtitle}</p>
				{
					changelogRows.length === 0 ? (
						<p class="hearth-copy hearth-doc-body text-[0.98rem]">{c.noReleaseNotes}</p>
					) : (
						<div class="grid gap-4">
							{
								changelogRows.map((entry) => (
									<article class="hearth-surface hearth-surface-soft hearth-card p-6">
										<div class="flex items-center justify-between gap-4 mb-3">
											<span class="font-mono text-[12.5px] hearth-doc-heading">{entry.version}</span>
