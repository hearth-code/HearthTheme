					</ul>
				</div>
			</section>

			<section class="hearth-surface hearth-card p-6 sm:p-8">
				<h2 class="font-ui font-semibold tracking-[-0.014em] text-[1.76rem] hearth-doc-heading mb-5">{c.protocolTitle}</h2>
