const tuningUrl = productData.links.tuningUrl;
const reportUrl = productData.links.reportUrl;
const contractChecklistUrl = productData.links.contractChecklistUrl;
const contractReviewUrl = productData.links.contractReviewUrl;
const CHANGELOG_VISIBLE_RELEASES = 6;
const CHANGELOG_VISIBLE_CHANGES = 2;

interface ExtensionReleaseRow {
	version: string;
	date: string;
	summary: string;
	changes: string[];
}

function parseExtensionChangelog(markdown: string): ExtensionReleaseRow[] {
	const rows: ExtensionReleaseRow[] = [];
	const normalized = markdown.replace(/\r\n/g, "\n");
	const sections = normalized.split(/\n(?=##\s+)/g);

	for (const section of sections) {
		const headerMatch = section.match(/^##\s+(\d+\.\d+\.\d+)(?:\s*-\s*(\d{4}-\d{2}-\d{2}))?/m);
		if (!headerMatch) continue;

		const [, version, date = ""] = headerMatch;
		const bullets = [...section.matchAll(/^- (.+)$/gm)].map((match) => match[1].trim()).filter(Boolean);
		if (bullets.length === 0) {
			throw new Error(`Release ${version} is missing bullet entries in extension/CHANGELOG.md.`);
		}

		const [summary, ...rest] = bullets;
		rows.push({
			version,
			date,
			summary,
			changes: rest,
		});
	}

	if (rows.length === 0) {
		throw new Error("No parseable release entries found in extension/CHANGELOG.md.");
	}

	return rows;
}

function readExtensionChangelogRows(): ExtensionReleaseRow[] {
	const changelogPath = new URL("../../../extension/CHANGELOG.md", import.meta.url);

	try {
		const content = readFileSync(changelogPath, "utf8");
		return parseExtensionChangelog(content);
	} catch (error) {
		throw new Error(
			`Baseline docs failed to load release history from ${changelogPath.pathname}: ${error instanceof Error ? error.message : String(error)}`,
		);
	}
}

