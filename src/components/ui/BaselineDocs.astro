								<th class="hearth-meta">{c.dark}</th>
								<th class="hearth-meta">{c.darkSoft}</th>
								<th class="hearth-meta">{c.light}</th>
								<th class="hearth-meta">{c.lightSoft}</th>
								<th class="hearth-meta">{c.narrative}</th>
