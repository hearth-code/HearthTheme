{
  "name": "hearthcode-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "node scripts/sync-themes.mjs && astro dev",
    "build": "node scripts/sync-themes.mjs && astro build",
    "preview": "astro preview",
    "generate:variants": "node scripts/generate-theme-variants.mjs",
    "generate:site-assets": "node scripts/generate-site-assets.mjs",
    "generate:obsidian": "node scripts/generate-obsidian-themes.mjs",
    "generate:obsidian:app": "node scripts/generate-obsidian-app-theme.mjs",
    "generate:color-report": "node scripts/generate-color-language-report.mjs",
    "generate:contract-checklist": "node scripts/generate-color-language-contract-checklist.mjs",
    "generate:contract-review": "node scripts/generate-color-language-contract-review.mjs",
    "generate:lineage": "node scripts/generate-color-language-lineage.mjs",
    "generate:parity": "node scripts/generate-color-language-parity.mjs",
    "sync": "node scripts/sync-themes.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:site": "node scripts/check-built-site.mjs",
    "verify": "pnpm run check:sync && pnpm run check:preview && pnpm run test && pnpm run audit:deps && pnpm run audit:all && pnpm run build && pnpm run test:site",
    "preview:generate": "node scripts/generate-preview-images.mjs",
    "check:sync": "node scripts/check-sync-clean.mjs",
    "check:schemes": "node scripts/check-schemes.mjs",
    "check:preview": "node scripts/check-preview-clean.mjs",
    "audit:deps": "pnpm audit --audit-level moderate",
    "audit:generated-origin": "node scripts/generated-origin-audit.mjs",
    "audit:theme": "node scripts/theme-audit.mjs",
    "audit:source-layer": "node scripts/audit-source-layer.mjs",
    "audit:contracts": "node scripts/audit-contract-checklist.mjs",
    "audit:contract-review": "node scripts/audit-contract-review.mjs",
    "audit:compatibility": "node scripts/audit-compatibility-boundaries.mjs",
    "audit:lineage": "node scripts/audit-lineage.mjs",
    "audit:parity": "node scripts/audit-parity.mjs",
    "audit:obsidian": "node scripts/obsidian-audit.mjs",
    "audit:copy": "node scripts/content-sync-audit.mjs",
    "audit:claims": "node scripts/claims-audit.mjs",
    "audit:cjk": "node scripts/cjk-audit.mjs",
    "audit:release": "node scripts/release-consistency-audit.mjs",
    "audit:all": "node scripts/theme-audit.mjs && node scripts/audit-source-layer.mjs && node scripts/audit-contract-checklist.mjs && node scripts/audit-contract-review.mjs && node scripts/check-schemes.mjs && node scripts/audit-lineage.mjs && node scripts/audit-parity.mjs && node scripts/audit-compatibility-boundaries.mjs && node scripts/obsidian-audit.mjs && node scripts/content-sync-audit.mjs && node scripts/claims-audit.mjs && node scripts/generated-origin-audit.mjs && node scripts/cjk-audit.mjs && node scripts/release-consistency-audit.mjs && node scripts/check-preview-clean.mjs",
    "bump:release:patch": "node scripts/bump-extension-version.mjs patch",
    "bump:release:minor": "node scripts/bump-extension-version.mjs minor",
    "bump:release:major": "node scripts/bump-extension-version.mjs major",
    "bump:ext:patch": "node scripts/bump-extension-version.mjs patch",
    "bump:ext:minor": "node scripts/bump-extension-version.mjs minor",
    "bump:ext:major": "node scripts/bump-extension-version.mjs major",
    "release:theme": "node scripts/release-theme.mjs",
    "generate:color-change-summary": "node scripts/generate-color-language-change-summary.mjs",
    "review:theme": "node scripts/theme-review-guide.mjs",
    "release:obsidian": "pnpm run audit:theme && pnpm run audit:obsidian && pnpm run pack:obsidian",
    "pack:ext": "node scripts/pack.mjs",
    "pack:local-preview": "node scripts/pack-local-preview.mjs",
    "pack:moss:local": "node scripts/pack-local-preview.mjs moss moss-local",
    "pack:obsidian": "node scripts/pack-obsidian.mjs",
    "pack:obsidian:snippets": "node scripts/pack-obsidian-snippets.mjs"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "sharp": "^0.34.4"
  },
  "pnpm": {
    "overrides": {
      "rollup": "npm:@rollup/wasm-node@4.60.2",
      "yaml": "^2.8.3"
    }
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.4"
  }
}
