        "gitDecoration.ignoredResourceForeground": "#a99f91",
        "gitDecoration.conflictingResourceForeground": "#b04935"
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#85776b",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#b04935",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#756f66",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "meta.function-call entity.name.function",
                "meta.function-call.js entity.name.function.js",
                "meta.function-call.ts entity.name.function.ts",
                "meta.function-call.py entity.name.function.py",
                "meta.function-call.python entity.name.function.python",
                "meta.function-call.go entity.name.function.go",
                "meta.function-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#456a80"
            }
        },
        {
            "scope": [
                "meta.method-call entity.name.function",
                "meta.method-call.js entity.name.function.js",
                "meta.method-call.ts entity.name.function.ts",
                "meta.method-call.py entity.name.function.py",
                "meta.method-call.python entity.name.function.python",
                "meta.method-call.go entity.name.function.go",
                "meta.method-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#906147"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#456a80"
            }
        },
        {
            "scope": [
                "entity.name.function.member",
                "entity.name.function.member.python",
                "entity.name.function.member.go",
                "entity.name.function.member.rust"
            ],
            "settings": {
                "foreground": "#906147"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "variable.other.member",
                "meta.property-name",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#5b6249"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#6c805a"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#8c5f75"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "storage.type.java",
                "storage.type.primitive.java",
                "entity.name.struct.rust",
                "entity.name.type.class",
                "support.type",
                "support.type.builtin",
                "support.class"
            ],
            "settings": {
                "foreground": "#836f2d",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#504c46"
            }
        },
        {
            "scope": [
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#8c4918"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#8f4400"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#7f3024"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#8d4400",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#6c5634"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#8c5f75"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#884a00",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#b6221b",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#914200",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#006b00"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#006b00"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#b31500",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#b31500",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#504c46",
        "variable.readonly": "#934100",
        "property": "#5b6249",
        "property.readonly": "#934100",
        "function": "#456a80",
        "method": "#906147",
        "function.defaultLibrary": "#456a80",
        "method.defaultLibrary": "#906147",
        "class": {
            "foreground": "#836f2d",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#836f2d",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#836f2d",
            "fontStyle": "italic"
        },
        "type.defaultLibrary": {
            "foreground": "#836f2d",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#836f2d",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#836f2d",
            "fontStyle": "italic"
        },
        "enumMember": "#8c5f75",
        "namespace": "#735431",
        "keyword": {
            "foreground": "#b04935",
            "fontStyle": "bold"
        },
        "parameter": "#5a4431",
        "variable.defaultLibrary": "#8d4400",
        "decorator": {
            "foreground": "#8d4400",
            "fontStyle": "italic"
        }
    }
}
