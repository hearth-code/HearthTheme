        "editor.selectionBackground": "#b8742b21",
        "editor.selectionHighlightBackground": "#b8742b12",
        "editor.wordHighlightBackground": "#b8742b15",
        "editor.findMatchBackground": "#b8742b2d",
        "editor.findMatchHighlightBackground": "#b8742b17",
        "editorLineNumber.foreground": "#a9967a",
        "editorLineNumber.activeForeground": "#876743",
        "editorCursor.foreground": "#b8742b",
        "editorWhitespace.foreground": "#cabca4",
        "editorIndentGuide.background1": "#cabca4",
        "editorIndentGuide.activeBackground1": "#a9967a",
        "editorBracketMatch.background": "#b8742b16",
