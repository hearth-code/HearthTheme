        "tab.border": "#d7d0c5",
        "tab.hoverBackground": "#e0d7c9",
        "tab.unfocusedActiveForeground": "#625a51",
        "editorGroupHeader.tabsBackground": "#e5ddd1",
        "editorGroupHeader.tabsBorder": "#d7d0c5",
