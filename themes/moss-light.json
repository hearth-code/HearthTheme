        "notifications.foreground": "#403730",
        "notifications.border": "#d6cec3",
        "notificationLink.foreground": "#b87911",
        "gitDecoration.addedResourceForeground": "#5a8290",
        "gitDecoration.modifiedResourceForeground": "#b17818",
        "gitDecoration.deletedResourceForeground": "#ba5146",
        "gitDecoration.untrackedResourceForeground": "#5a8290",
        "gitDecoration.ignoredResourceForeground": "#a89f95",
        "gitDecoration.conflictingResourceForeground": "#ba5146"
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#887d70",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#ba5146",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#6e665d",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "meta.function-call entity.name.function",
                "meta.function-call.js entity.name.function.js",
                "meta.function-call.ts entity.name.function.ts",
                "meta.function-call.py entity.name.function.py",
                "meta.function-call.python entity.name.function.python",
                "meta.function-call.go entity.name.function.go",
                "meta.function-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#5b818f"
            }
        },
        {
            "scope": [
                "meta.method-call entity.name.function",
                "meta.method-call.js entity.name.function.js",
                "meta.method-call.ts entity.name.function.ts",
                "meta.method-call.py entity.name.function.py",
                "meta.method-call.python entity.name.function.python",
                "meta.method-call.go entity.name.function.go",
                "meta.method-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#608e85"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#5b818f"
            }
        },
        {
            "scope": [
                "entity.name.function.member",
                "entity.name.function.member.python",
                "entity.name.function.member.go",
                "entity.name.function.member.rust"
            ],
            "settings": {
                "foreground": "#608e85"
            }
        },
        {
            "scope": [
                "variable.other.property",
                "variable.other.member",
                "meta.property-name",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#60776f"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#b2862e"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#a26179"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "storage.type.java",
                "storage.type.primitive.java",
                "entity.name.struct.rust",
                "entity.name.type.class",
                "support.type",
                "support.type.builtin",
                "support.class"
            ],
            "settings": {
                "foreground": "#456f79",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#504c46"
            }
        },
        {
            "scope": [
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#794825"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#864e1d"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#bb6934"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#8a5319",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#a48f70"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#a26179"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#714500",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#953328",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#8e5313",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#14731c"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#14731c"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#ac4226",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#ac4226",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#504c46",
        "variable.readonly": "#975616",
        "property": "#60776f",
        "property.readonly": "#975616",
        "function": "#5b818f",
        "method": "#608e85",
        "function.defaultLibrary": "#5b818f",
        "method.defaultLibrary": "#608e85",
        "class": {
            "foreground": "#456f79",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#456f79",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#456f79",
            "fontStyle": "italic"
        },
        "type.defaultLibrary": {
            "foreground": "#456f79",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#456f79",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#456f79",
            "fontStyle": "italic"
        },
        "enumMember": "#a26179",
        "namespace": "#443319",
        "keyword": {
            "foreground": "#ba5146",
            "fontStyle": "bold"
        },
        "parameter": "#5d524a",
        "variable.defaultLibrary": "#8a5319",
        "decorator": {
            "foreground": "#8a5319",
            "fontStyle": "italic"
        }
    }
}
