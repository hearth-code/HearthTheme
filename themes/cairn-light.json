        "tab.activeBorder": "#ae7245",
        "tab.inactiveBackground": "#ddd5ca",
        "tab.inactiveForeground": "#857c72",
        "tab.border": "#c8bfb6",
        "tab.hoverBackground": "#ddd5cc",
        "tab.unfocusedActiveForeground": "#5b5249",
        "editorGroupHeader.tabsBackground": "#ddd5ca",
        "editorGroupHeader.tabsBorder": "#c8bfb6",
        "panel.background": "#ddd5ca",
