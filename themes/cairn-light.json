        "panelTitle.activeForeground": "#31271f",
        "panelTitle.inactiveForeground": "#857c72",
        "terminal.background": "#e6ded4",
        "terminal.foreground": "#2d241d",
        "terminal.ansiBlack": "#3c332b",
        "terminal.ansiRed": "#a94731",
        "terminal.ansiGreen": "#526a45",
        "terminal.ansiYellow": "#7e6c48",
        "terminal.ansiBlue": "#587182",
        "terminal.ansiMagenta": "#7a5540",
        "terminal.ansiCyan": "#587166",
        "terminal.ansiWhite": "#5a4838",
        "terminal.ansiBrightBlack": "#7e7467",
        "terminal.ansiBrightRed": "#b65a42",
        "terminal.ansiBrightGreen": "#627b54",
        "terminal.ansiBrightYellow": "#8f7d56",
        "terminal.ansiBrightBlue": "#677f90",
        "terminal.ansiBrightMagenta": "#88644e",
        "terminal.ansiBrightCyan": "#667f74",
        "terminal.ansiBrightWhite": "#3b2f24",
        "terminalCursor.foreground": "#ae7245",
        "input.background": "#dad2c8",
        "input.foreground": "#31271f",
        "input.border": "#cac2b7",
