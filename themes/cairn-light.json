        "scrollbarSlider.activeBackground": "#b49d7baa",
        "badge.background": "#ae7245",
        "badge.foreground": "#ffffff",
        "progressBar.background": "#ae7245",
        "focusBorder": "#ae724545",
        "selection.background": "#ae724521",
        "widget.shadow": "#00000033",
        "notifications.background": "#dad2c8",
        "notifications.foreground": "#31271f",
        "notifications.border": "#cac2b7",
        "notificationLink.foreground": "#ae7245",
        "gitDecoration.addedResourceForeground": "#728064",
        "gitDecoration.modifiedResourceForeground": "#ae7245",
        "gitDecoration.deletedResourceForeground": "#a8553d",
        "gitDecoration.untrackedResourceForeground": "#728064",
        "gitDecoration.ignoredResourceForeground": "#a79e94",
        "gitDecoration.conflictingResourceForeground": "#a8553d"
    },
    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7d7469",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "foreground": "#ab553d",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "keyword.operator.assignment"
            ],
            "settings": {
                "foreground": "#635947",
                "fontStyle": ""
            }
        },
        {
            "scope": [
                "meta.function-call entity.name.function",
                "meta.function-call.js entity.name.function.js",
                "meta.function-call.ts entity.name.function.ts",
                "meta.function-call.py entity.name.function.py",
                "meta.function-call.python entity.name.function.python",
                "meta.function-call.go entity.name.function.go",
                "meta.function-call.rust entity.name.function.rust",
                "meta.method-call entity.name.function",
                "meta.method-call.js entity.name.function.js",
                "meta.method-call.ts entity.name.function.ts",
                "meta.method-call.py entity.name.function.py",
                "meta.method-call.python entity.name.function.python",
                "meta.method-call.go entity.name.function.go",
                "meta.method-call.rust entity.name.function.rust"
            ],
            "settings": {
                "foreground": "#89644b"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call.generic"
            ],
            "settings": {
                "foreground": "#597283"
            }
        },
        {
            "scope": [
                "entity.name.function.member",
                "entity.name.function.member.python",
                "entity.name.function.member.go",
                "entity.name.function.member.rust",
                "variable.other.property",
                "variable.other.member",
                "meta.property-name",
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#565e4e"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "string.regexp"
            ],
            "settings": {
                "foreground": "#747f69"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined"
            ],
            "settings": {
                "foreground": "#b17345"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "storage.type.java",
                "storage.type.primitive.java",
                "entity.name.struct.rust",
                "entity.name.type.class",
                "support.type",
                "support.type.builtin",
                "support.class"
            ],
            "settings": {
                "foreground": "#837348",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other.readwrite",
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#59493a"
            }
        },
        {
            "scope": [
                "meta.object-literal.key"
            ],
            "settings": {
                "foreground": "#854e27"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#844714"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#894a3b"
            }
        },
        {
            "scope": [
                "meta.decorator",
                "punctuation.decorator"
            ],
            "settings": {
                "foreground": "#854b0c",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "punctuation",
                "meta.brace"
            ],
            "settings": {
                "foreground": "#735a37"
            }
        },
        {
            "scope": [
                "constant.other.color",
                "support.constant"
            ],
            "settings": {
                "foreground": "#b17345"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#7d4c00",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#a33629",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.italic"
            ],
            "settings": {
                "foreground": "#894900",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#006a07"
            }
        },
        {
            "scope": [
                "markup.underline.link"
            ],
            "settings": {
                "foreground": "#006a07"
            }
        },
        {
            "scope": [
                "invalid.deprecated"
            ],
            "settings": {
                "foreground": "#a02f13",
                "fontStyle": "strikethrough"
            }
        },
        {
            "scope": [
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#a02f13",
                "fontStyle": "underline"
            }
        }
    ],
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "variable": "#59493a",
        "variable.readonly": "#884600",
        "property": "#565e4e",
        "property.readonly": "#884600",
        "function": "#597283",
        "method": "#89644b",
        "function.defaultLibrary": "#89644b",
        "method.defaultLibrary": "#89644b",
        "class": {
            "foreground": "#837348",
            "fontStyle": "italic"
        },
        "interface": {
            "foreground": "#837348",
            "fontStyle": "italic"
        },
        "type": {
            "foreground": "#837348",
            "fontStyle": "italic"
        },
        "type.defaultLibrary": {
            "foreground": "#837348",
            "fontStyle": "italic"
        },
        "typeParameter": {
            "foreground": "#837348",
            "fontStyle": "italic"
        },
        "enum": {
            "foreground": "#837348",
            "fontStyle": "italic"
        },
        "enumMember": "#b17345",
        "namespace": "#695338",
        "keyword": {
            "foreground": "#ab553d",
            "fontStyle": "bold"
        },
        "parameter": "#5b4b3c",
        "variable.defaultLibrary": "#854b0c",
        "decorator": {
            "foreground": "#854b0c",
            "fontStyle": "italic"
        }
    }
}
