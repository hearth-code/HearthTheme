        "statusBar.background": "#a86b39",
        "statusBar.foreground": "#faf1e8",
        "statusBar.border": "#c8bfb6",
        "statusBar.noFolderBackground": "#8a562d",
        "statusBar.debuggingBackground": "#7f4313",
        "statusBarItem.hoverBackground": "#ae724526",
        "statusBarItem.activeBackground": "#ae724533",
        "titleBar.activeBackground": "#ddd5ca",
